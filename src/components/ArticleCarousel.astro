---
// Horizontal scroll carousel — 2 rows, arrow navigation, snap scroll
interface Article {
  title: string;
  description: string;
  destination: string;
  category: string;
  slug: string;
  heroImage?: string;
  readingTime: number;
  city?: string;
}

interface Props {
  articles: Article[];
  id?: string;
}

const { articles, id = 'carousel' } = Astro.props;
---

<div class="relative">
  <!-- Arrows -->
  <button
    id={`${id}-prev`}
    class="hidden md:flex absolute -left-5 top-1/2 -translate-y-1/2 z-10 w-10 h-10 items-center justify-center bg-white border border-[var(--color-border)] rounded-full shadow-sm hover:shadow-md transition-shadow text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]"
    aria-label="Previous"
  >
    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
  </button>

  <button
    id={`${id}-next`}
    class="hidden md:flex absolute -right-5 top-1/2 -translate-y-1/2 z-10 w-10 h-10 items-center justify-center bg-white border border-[var(--color-border)] rounded-full shadow-sm hover:shadow-md transition-shadow text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]"
    aria-label="Next"
  >
    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
  </button>

  <!-- Scroll track -->
  <div
    id={`${id}-track`}
    class="overflow-x-auto scrollbar-hide pb-2"
    style="scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;"
  >
    <!-- 2-row grid, auto-flowing columns -->
    <div
      class="grid gap-4"
      style="grid-template-rows: repeat(2, auto); grid-auto-flow: column; grid-auto-columns: 272px;"
    >
      {articles.map((article) => (
        <a
          href={`/${article.destination.toLowerCase()}/${article.slug}`}
          class="group block bg-white rounded-xl overflow-hidden border border-[var(--color-border)] hover:shadow-md transition-shadow"
          style="scroll-snap-align: start; width: 272px;"
        >
          <!-- Image -->
          <div class="relative h-36 overflow-hidden bg-[var(--color-bg)]">
            {article.heroImage ? (
              <img
                src={article.heroImage}
                alt={article.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            ) : (
              <div class="w-full h-full bg-gradient-to-br from-[var(--color-brand-50)] to-[var(--color-brand-100)] flex items-center justify-center">
                <span class="text-[var(--color-brand-600)] text-3xl">✦</span>
              </div>
            )}
            <span class="absolute top-2.5 left-2.5 bg-white/90 backdrop-blur-sm text-xs font-semibold uppercase tracking-wider text-[var(--color-brand-600)] px-2 py-0.5 rounded-full">
              {article.category}
            </span>
          </div>
          <!-- Content -->
          <div class="p-4">
            <h3
              class="text-sm font-bold text-[var(--color-text-primary)] leading-snug mb-1.5 group-hover:text-[var(--color-brand-600)] transition-colors line-clamp-2"
              style="font-family: var(--font-display);"
            >
              {article.title}
            </h3>
            <div class="flex items-center justify-between mt-2">
              <span class="text-xs text-[var(--color-text-muted)]">{article.readingTime} min</span>
              <span class="text-xs font-semibold text-[var(--color-brand-600)] group-hover:translate-x-0.5 transition-transform inline-block">→</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</div>

<!-- Hide scrollbar cross-browser -->
<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[id$="-track"]').forEach((track) => {
    const baseId = track.id.replace('-track', '');
    const prev = document.getElementById(`${baseId}-prev`);
    const next = document.getElementById(`${baseId}-next`);
    const cardWidth = 272 + 16; // card width + gap

    prev?.addEventListener('click', () => track.scrollBy({ left: -cardWidth * 2, behavior: 'smooth' }));
    next?.addEventListener('click', () => track.scrollBy({ left: cardWidth * 2, behavior: 'smooth' }));

    // Show/hide arrows based on scroll position
    function updateArrows() {
      const atStart = track.scrollLeft <= 8;
      const atEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 8;
      if (prev) prev.style.opacity = atStart ? '0.3' : '1';
      if (next) next.style.opacity = atEnd ? '0.3' : '1';
    }
    track.addEventListener('scroll', updateArrows, { passive: true });
    updateArrows();
  });
</script>
