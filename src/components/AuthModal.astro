---
/**
 * AuthModal — Supabase auth overlay
 * Supports: Email/Password + Google OAuth
 * Triggered by: data-auth-trigger attribute on any element
 * Context passed via: data-auth-context="comment|sync|default"
 * Default mode: signup
 */
---

<div
  id="auth-modal-overlay"
  class="hidden fixed inset-0 z-[300] flex items-center justify-center"
  style="background: rgba(0,0,0,0.45); backdrop-filter: blur(4px);"
  aria-modal="true"
  role="dialog"
  aria-label="Sign in"
>
  <div
    id="auth-modal"
    class="relative bg-[var(--color-bg)] rounded-2xl shadow-2xl w-full flex flex-col"
    style="max-width: 420px; padding: 2rem 2rem 1.75rem; margin: 1rem;"
  >
    <!-- Close -->
    <button
      id="auth-modal-close"
      class="absolute top-4 right-4 text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors"
      aria-label="Close"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <!-- ── Check-email state (shown after signup) ────────────────── -->
    <div id="auth-check-email" class="hidden text-center py-4">
      <div class="w-14 h-14 rounded-full bg-[var(--color-brand-50)] flex items-center justify-center mx-auto mb-5">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-brand-600)]">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </div>
      <h3 class="text-lg font-bold text-[var(--color-text-primary)] mb-2" style="font-family: var(--font-display)">
        Check your inbox
      </h3>
      <p class="text-sm text-[var(--color-text-secondary)] mb-1">
        We sent a confirmation email to:
      </p>
      <p id="auth-confirm-email-addr" class="text-sm font-semibold text-[var(--color-brand-600)] mb-4 break-all"></p>
      <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">
        Click the link in that email to activate your account.<br/>
        It may take a minute or two to arrive.
      </p>
      <button
        id="auth-check-email-back"
        class="mt-6 text-xs text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] underline"
      >
        Back to sign up
      </button>
    </div>

    <!-- ── Main auth form ────────────────────────────────────────── -->
    <div id="auth-main-form">
      <!-- Header -->
      <div class="mb-6">
        <h2 id="auth-modal-title" class="text-xl font-bold text-[var(--color-text-primary)]" style="font-family: var(--font-display);">
          Create your account
        </h2>
        <p id="auth-modal-subtitle" class="text-sm text-[var(--color-text-secondary)] mt-1"></p>
      </div>

      <!-- Error banner -->
      <div id="auth-error" class="hidden mb-4 px-3 py-2.5 rounded-lg bg-red-50 border border-red-200 text-sm text-red-700"></div>

      <!-- Google OAuth -->
      <button
        id="auth-google-btn"
        class="flex items-center justify-center gap-3 w-full border border-[var(--color-border)] rounded-xl px-4 py-3 text-sm font-medium text-[var(--color-text-primary)] hover:bg-[var(--color-surface)] transition-colors mb-3"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Continue with Google
      </button>

      <!-- Divider -->
      <div class="flex items-center gap-3 my-3">
        <div class="flex-1 h-px bg-[var(--color-border)]"></div>
        <span class="text-xs text-[var(--color-text-muted)]">or</span>
        <div class="flex-1 h-px bg-[var(--color-border)]"></div>
      </div>

      <!-- Email form -->
      <form id="auth-email-form" class="flex flex-col gap-3">
        <input
          id="auth-email"
          type="email"
          placeholder="Email address"
          required
          autocomplete="email"
          class="w-full px-4 py-3 rounded-xl border border-[var(--color-border)] text-sm text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] bg-[var(--color-bg)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-300)] transition-all"
        />
        <input
          id="auth-password"
          type="password"
          placeholder="Create a password"
          required
          autocomplete="new-password"
          class="w-full px-4 py-3 rounded-xl border border-[var(--color-border)] text-sm text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] bg-[var(--color-bg)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-300)] transition-all"
        />

        <!-- Forgot password (login mode only) -->
        <div id="auth-forgot-row" class="hidden justify-end -mt-1">
          <button type="button" id="auth-forgot-btn" class="text-xs text-[var(--color-brand-600)] hover:underline">
            Forgot password?
          </button>
        </div>

        <button
          type="submit"
          id="auth-submit-btn"
          class="w-full bg-[var(--color-brand-600)] hover:bg-[var(--color-brand-500)] text-white font-semibold text-sm rounded-xl px-4 py-3 transition-colors disabled:opacity-60"
        >
          Create account
        </button>
      </form>

      <!-- Toggle login / signup -->
      <p class="text-center text-sm text-[var(--color-text-secondary)] mt-4">
        <span id="auth-toggle-text">Already have an account?</span>
        <button id="auth-toggle-btn" class="text-[var(--color-brand-600)] font-semibold hover:underline ml-1">
          Sign in
        </button>
      </p>
    </div><!-- /#auth-main-form -->
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase';

  const overlay       = document.getElementById('auth-modal-overlay')!;
  const closeBtn      = document.getElementById('auth-modal-close')!;
  const title         = document.getElementById('auth-modal-title')!;
  const subtitle      = document.getElementById('auth-modal-subtitle')!;
  const errorBox      = document.getElementById('auth-error')!;
  const googleBtn     = document.getElementById('auth-google-btn')!;
  const form          = document.getElementById('auth-email-form') as HTMLFormElement;
  const emailEl       = document.getElementById('auth-email') as HTMLInputElement;
  const passEl        = document.getElementById('auth-password') as HTMLInputElement;
  const submitBtn     = document.getElementById('auth-submit-btn')!;
  const toggleBtn     = document.getElementById('auth-toggle-btn')!;
  const toggleTxt     = document.getElementById('auth-toggle-text')!;
  const forgotRow     = document.getElementById('auth-forgot-row')!;
  const forgotBtn     = document.getElementById('auth-forgot-btn')!;
  const checkEmailDiv = document.getElementById('auth-check-email')!;
  const mainFormDiv   = document.getElementById('auth-main-form')!;
  const confirmAddr   = document.getElementById('auth-confirm-email-addr')!;
  const backBtn       = document.getElementById('auth-check-email-back')!;

  let isSignup = true; // default: signup
  let pendingAction: (() => void) | null = null;

  // ── Open / close ─────────────────────────────────────────────────────────
  function openModal(context: string = 'default', onSuccess?: () => void) {
    isSignup = true;
    setMode(true);
    clearError();
    showMainForm();
    pendingAction = onSuccess ?? null;

    const subtitles: Record<string, string> = {
      comment: 'Sign in to leave a comment.',
      sync:    'Sign in to sync your saves across devices.',
      default: '',
    };
    subtitle.textContent = subtitles[context] ?? '';
    overlay.classList.remove('hidden');
    emailEl.focus();
  }

  function closeModal() {
    overlay.classList.add('hidden');
    form.reset();
    clearError();
    showMainForm();
    pendingAction = null;
  }

  function showMainForm() {
    mainFormDiv.classList.remove('hidden');
    checkEmailDiv.classList.add('hidden');
  }

  function showCheckEmail(email: string) {
    mainFormDiv.classList.add('hidden');
    checkEmailDiv.classList.remove('hidden');
    confirmAddr.textContent = email;
  }

  function setMode(signup: boolean) {
    isSignup = signup;
    title.textContent     = signup ? 'Create your account' : 'Sign in to GoinAtlas';
    submitBtn.textContent = signup ? 'Create account' : 'Sign in';
    toggleTxt.textContent = signup ? 'Already have an account?' : "Don't have an account?";
    toggleBtn.textContent = signup ? 'Sign in' : 'Create one';
    // show/hide forgot row
    if (signup) {
      forgotRow.classList.add('hidden');
      forgotRow.style.display = '';
    } else {
      forgotRow.classList.remove('hidden');
      forgotRow.style.display = 'flex';
    }
    (passEl as HTMLInputElement).placeholder = signup ? 'Create a password' : 'Password';
    (passEl as HTMLInputElement).autocomplete = signup ? 'new-password' : 'current-password';
  }

  function showError(msg: string) {
    errorBox.textContent = msg;
    errorBox.classList.remove('hidden');
  }

  function clearError() {
    errorBox.textContent = '';
    errorBox.classList.add('hidden');
  }

  // ── Trigger from any element with data-auth-trigger ───────────────────────
  document.addEventListener('click', (e) => {
    const trigger = (e.target as HTMLElement).closest('[data-auth-trigger]') as HTMLElement | null;
    if (trigger) {
      const ctx = trigger.dataset.authContext ?? 'default';
      openModal(ctx);
    }
  });

  // Expose globally for programmatic use
  (window as any).goinAtlasAuth = { open: openModal, close: closeModal };

  closeBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
  toggleBtn.addEventListener('click', () => setMode(!isSignup));
  backBtn.addEventListener('click', () => { showMainForm(); form.reset(); });

  // ── Google OAuth ─────────────────────────────────────────────────────────
  googleBtn.addEventListener('click', async () => {
    clearError();
    const { error } = await supabase.auth.signInWithOAuth({
      provider: 'google',
      options: { redirectTo: `${window.location.origin}/onboarding` },
    });
    if (error) showError(error.message);
  });

  // ── Email / Password ─────────────────────────────────────────────────────
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearError();
    submitBtn.setAttribute('disabled', 'true');

    const email    = emailEl.value.trim();
    const password = passEl.value;

    try {
      if (isSignup) {
        const { error } = await supabase.auth.signUp({
          email,
          password,
          options: { emailRedirectTo: `${window.location.origin}/onboarding` },
        });
        if (error) throw error;
        // Show "check your email" — don't close or redirect yet
        showCheckEmail(email);
      } else {
        const { error } = await supabase.auth.signInWithPassword({ email, password });
        if (error) throw error;
        closeModal();
        await migrateSaves();
        pendingAction?.();
        document.dispatchEvent(new CustomEvent('goinatlas:authChanged'));
      }
    } catch (err: any) {
      showError(err.message ?? 'Something went wrong. Please try again.');
    } finally {
      submitBtn.removeAttribute('disabled');
    }
  });

  // ── Forgot password ───────────────────────────────────────────────────────
  forgotBtn.addEventListener('click', async () => {
    const email = emailEl.value.trim();
    if (!email) { showError('Enter your email address first.'); return; }
    clearError();
    const { error } = await supabase.auth.resetPasswordForEmail(email, {
      redirectTo: `${window.location.origin}/account`,
    });
    if (error) showError(error.message);
    else showError('Password reset email sent. Check your inbox.');
  });

  // ── Migrate localStorage saves → Supabase ────────────────────────────────
  async function migrateSaves() {
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) return;

    const RL_KEY = 'goinatlas:reading-list';
    let slugs: string[] = [];
    try { slugs = JSON.parse(localStorage.getItem(RL_KEY) ?? '[]'); } catch {}
    if (slugs.length === 0) return;

    let articles: any[] = [];
    try {
      const res = await fetch('/search.json');
      articles = await res.json();
    } catch {}

    for (const slug of slugs) {
      const article = articles.find((a: any) => a.slug === slug || slug.includes(a.slug));
      if (!article) continue;
      await supabase.from('saved_articles').upsert({
        user_id:      user.id,
        article_slug: slug,
        destination:  article.destination ?? '',
        title:        article.title ?? slug,
        hero_image:   article.heroImage ?? null,
      }, { onConflict: 'user_id,article_slug' });
    }

    localStorage.removeItem(RL_KEY);
  }
</script>
