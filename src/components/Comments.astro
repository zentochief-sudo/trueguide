---
// Giscus comments — requires GitHub repo to be public and Giscus app installed
// Setup: https://giscus.app — configure repo, then replace data attributes below
// TODO: Update data-repo, data-repo-id, data-category-id after GitHub setup
---

<div class="border-t border-[var(--color-border)] pt-10">
  <h3 class="text-lg font-bold text-[var(--color-text-primary)] mb-6" style="font-family: var(--font-display)">
    Share your experience
  </h3>

  <!-- Giscus embed — replace with values from giscus.app once repo is configured -->
  <script
    is:inline
    src="https://giscus.app/client.js"
    data-repo="zentochief-sudo/trueguide"
    data-repo-id="REPLACE_WITH_REPO_ID"
    data-category="General"
    data-category-id="REPLACE_WITH_CATEGORY_ID"
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="top"
    data-theme="light"
    data-lang="en"
    data-loading="lazy"
    crossorigin="anonymous"
    async
  ></script>
</div>
