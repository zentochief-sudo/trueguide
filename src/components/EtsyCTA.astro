---
interface Props {
  label: string;
  url: string;
  position: 'top' | 'bottom';
}

const { label, url, position } = Astro.props;
---

<div class:list={[
  "flex items-center gap-4 bg-[var(--color-brand-50)] border border-[var(--color-brand-100)] rounded-xl p-5",
  position === 'top' ? "mb-8" : "mt-8"
]}>
  <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[var(--color-brand-600)] flex items-center justify-center">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
      <polyline points="14 2 14 8 20 8"/>
      <line x1="16" y1="13" x2="8" y2="13"/>
      <line x1="16" y1="17" x2="8" y2="17"/>
      <polyline points="10 9 9 9 8 9"/>
    </svg>
  </div>
  <div class="flex-1 min-w-0">
    <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand-600)] mb-0.5">Plan your trip</p>
    <p class="text-sm text-[var(--color-text-secondary)] truncate">{label}</p>
  </div>
  <a
    href={url}
    target="_blank"
    rel="noopener noreferrer"
    class="flex-shrink-0 bg-[var(--color-brand-600)] hover:bg-[var(--color-brand-700)] text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors"
  >
    Download →
  </a>
</div>
