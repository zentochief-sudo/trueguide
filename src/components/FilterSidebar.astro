---
// Filter sidebar — city + category + activity type filters
// Dispatches: goinatlas:cityFilter, goinatlas:categoryFilter, goinatlas:typeFilter

interface Props {
  cities: Array<{ id: string; label: string; count: number }>;
  destination: string;
}

const { cities, destination } = Astro.props;

const categories = [
  { id: 'Itinerary',  label: 'Itinerary' },
  { id: 'Culture',    label: 'Culture' },
  { id: 'Food',       label: 'Food & Drink' },
  { id: 'Tips',       label: 'Tips & Practical' },
  { id: 'Transport',  label: 'Transport' },
  { id: 'Budget',     label: 'Budget' },
];

const activityTypes = [
  { id: 'food-drink',    label: 'Food & Drink' },
  { id: 'shrines',       label: 'Shrines' },
  { id: 'onsen',         label: 'Onsen' },
  { id: 'parks',         label: 'Parks & Gardens' },
  { id: 'temples',       label: 'Temples' },
  { id: 'castles',       label: 'Castles' },
  { id: 'architecture',  label: 'Architecture' },
  { id: 'crafts',        label: 'Crafts' },
  { id: 'festivals',     label: 'Festivals' },
  { id: 'nature',        label: 'Nature & Rural' },
  { id: 'manga-anime',   label: 'Manga & Anime' },
  { id: 'museums',       label: 'Museums & Theatre' },
  { id: 'shopping',      label: 'Shopping' },
  { id: 'history',       label: 'History' },
  { id: 'luxury',        label: 'Luxury Travel' },
];
---

<style>
  /* ── Base filter button ───────────────────────────────────── */
  .filter-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.45rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    background: transparent;
    transition: background 0.15s, color 0.15s;
    cursor: pointer;
    text-align: left;
    border: none;
  }
  .filter-btn:hover:not(:disabled) {
    background: var(--color-bg);
    color: var(--color-text-primary);
  }
  .filter-btn.is-active {
    background: var(--color-brand-50);
    color: var(--color-brand-600);
    font-weight: 600;
  }
  .filter-btn.is-active:hover {
    background: var(--color-brand-100, var(--color-brand-50));
  }
  /* Disabled state */
  .filter-btn:disabled,
  .filter-btn.is-disabled {
    opacity: 0.35;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* ── Checkbox visual ────────────────────────────────────────── */
  .filter-check {
    flex-shrink: 0;
    width: 13px;
    height: 13px;
    border-radius: 3px;
    border: 1.5px solid var(--color-border);
    background: white;
    background-repeat: no-repeat;
    background-position: center;
    background-size: 9px 7px;
    transition: background-color 0.12s, border-color 0.12s;
  }
  .filter-btn.is-active .filter-check {
    background-color: var(--color-brand-600);
    border-color: var(--color-brand-600);
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 10 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 4l2.5 2.5L9 1' stroke='white' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  }

  /* ── Chip remove button ─────────────────────────────────────── */
  .chip-remove {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0 0 0 2px;
    font-size: 0.8rem;
    line-height: 1;
    color: var(--color-brand-600);
    opacity: 0.6;
    transition: opacity 0.15s;
  }
  .chip-remove:hover { opacity: 1; }
</style>

<aside id="filter-sidebar" class="w-full md:w-52 flex-shrink-0">
  <div class="space-y-5">

    <!-- Active filters chips -->
    <div id="active-filters-bar" class="hidden">
      <div class="flex flex-wrap gap-1.5" id="active-chips"></div>
      <button id="clear-all-filters" class="mt-2 text-xs text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors">
        Clear all ×
      </button>
    </div>

    <!-- City -->
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-text-muted)] mb-2">City</p>
      <ul class="space-y-0.5" id="city-filter-list">
        <li>
          <button class="filter-btn city-filter-btn is-active" data-city="all" data-label={`All ${destination}`}>
            <span>All {destination}</span>
            <span class="text-xs text-[var(--color-text-muted)]">{cities.reduce((s, c) => s + c.count, 0)}</span>
          </button>
        </li>
        {cities.map((city) => (
          <li>
            <button class="filter-btn city-filter-btn" data-city={city.id} data-label={city.label}>
              <span class="flex items-center gap-2 flex-1 min-w-0">
                <span class="filter-check" aria-hidden="true"></span>
                <span class="truncate">{city.label}</span>
              </span>
              <span class="text-xs text-[var(--color-text-muted)] ml-1 flex-shrink-0">{city.count}</span>
            </button>
          </li>
        ))}
      </ul>
    </div>

    <div class="border-t border-[var(--color-border)]"></div>

    <!-- Category -->
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-text-muted)] mb-2">Category</p>
      <ul class="space-y-0.5" id="category-filter-list">
        {categories.map((cat) => (
          <li>
            <button class="filter-btn category-filter-btn" data-category={cat.id} data-label={cat.label}>
              <span class="flex items-center gap-2">
                <span class="filter-check" aria-hidden="true"></span>
                <span>{cat.label}</span>
              </span>
            </button>
          </li>
        ))}
      </ul>
    </div>

    <div class="border-t border-[var(--color-border)]"></div>

    <!-- Activity type -->
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-text-muted)] mb-2">Type</p>
      <ul class="space-y-0.5" id="type-filter-list">
        {activityTypes.map((type) => (
          <li>
            <button class="filter-btn type-filter-btn" data-type={type.id} data-label={type.label}>
              <span class="flex items-center gap-2">
                <span class="filter-check" aria-hidden="true"></span>
                <span>{type.label}</span>
              </span>
            </button>
          </li>
        ))}
      </ul>
    </div>

  </div>
</aside>

<script>
  // ── City filter ───────────────────────────────────────────────
  const cityBtns = document.querySelectorAll<HTMLButtonElement>('.city-filter-btn');

  function setCityActive(cityId: string, dispatch = true) {
    cityBtns.forEach((btn) => {
      btn.classList.toggle('is-active', btn.dataset.city === cityId);
    });
    if (dispatch) {
      document.dispatchEvent(new CustomEvent('goinatlas:cityFilter', { detail: { city: cityId } }));
    }
    updateChips();
  }

  cityBtns.forEach((btn) => btn.addEventListener('click', () => setCityActive(btn.dataset.city!)));

  document.addEventListener('goinatlas:cityFilter', ((e: CustomEvent) => {
    setCityActive(e.detail.city, false);
  }) as EventListener);

  // ── Category filter ───────────────────────────────────────────
  const catBtns = document.querySelectorAll<HTMLButtonElement>('.category-filter-btn');
  let activeCategory: string | null = null;

  function setCategoryActive(catId: string | null) {
    activeCategory = catId;
    catBtns.forEach((btn) => {
      btn.classList.toggle('is-active', btn.dataset.category === catId);
    });
    document.dispatchEvent(new CustomEvent('goinatlas:categoryFilter', { detail: { category: catId } }));
    updateChips();
  }

  catBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      setCategoryActive(btn.dataset.category === activeCategory ? null : btn.dataset.category!);
    });
  });

  // ── Activity type filter ──────────────────────────────────────
  const typeBtns = document.querySelectorAll<HTMLButtonElement>('.type-filter-btn');
  let activeType: string | null = null;

  function setTypeActive(typeId: string | null) {
    activeType = typeId;
    typeBtns.forEach((btn) => {
      btn.classList.toggle('is-active', btn.dataset.type === typeId);
    });
    document.dispatchEvent(new CustomEvent('goinatlas:typeFilter', { detail: { type: typeId } }));
    updateChips();
  }

  typeBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      setTypeActive(btn.dataset.type === activeType ? null : btn.dataset.type!);
    });
  });

  // ── Active filter chips (with individual × remove) ────────────
  const chipsBar = document.getElementById('active-filters-bar');
  const chipsEl  = document.getElementById('active-chips');
  const clearAll = document.getElementById('clear-all-filters');

  function updateChips() {
    if (!chipsEl || !chipsBar) return;

    type Chip = { label: string; type: 'city' | 'category' | 'type' };
    const chips: Chip[] = [];

    const activeCity = [...cityBtns].find((b) => b.classList.contains('is-active'));
    if (activeCity && activeCity.dataset.city !== 'all') {
      chips.push({ label: activeCity.dataset.label!, type: 'city' });
    }
    if (activeCategory) {
      const btn = [...catBtns].find((b) => b.dataset.category === activeCategory);
      if (btn) chips.push({ label: btn.dataset.label!, type: 'category' });
    }
    if (activeType) {
      const btn = [...typeBtns].find((b) => b.dataset.type === activeType);
      if (btn) chips.push({ label: btn.dataset.label!, type: 'type' });
    }

    chipsEl.innerHTML = chips.map((c) =>
      `<span class="inline-flex items-center gap-0.5 pl-2 pr-1 py-0.5 text-xs font-medium rounded-full bg-[var(--color-brand-50)] text-[var(--color-brand-600)]">
        ${c.label}
        <button class="chip-remove" data-chip-remove="${c.type}" aria-label="Remove ${c.label} filter">×</button>
      </span>`
    ).join('');

    chipsBar.classList.toggle('hidden', chips.length === 0);
  }

  // Event delegation for chip × buttons
  chipsEl?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-chip-remove]');
    if (!btn) return;
    const type = btn.dataset.chipRemove as 'city' | 'category' | 'type';
    if (type === 'city')     setCityActive('all');
    if (type === 'category') setCategoryActive(null);
    if (type === 'type')     setTypeActive(null);
  });

  clearAll?.addEventListener('click', () => {
    setCityActive('all');
    setCategoryActive(null);
    setTypeActive(null);
  });
</script>
