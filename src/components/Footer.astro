---
// Footer — fixed at bottom of right sidebar column
// Aligns with Recommended Cities (pl-8 = 2rem from the border)
---

<div
  id="site-footer"
  class="fixed bottom-0 right-0 bg-[var(--color-bg)] z-30 hidden xl:block"
  style="width: 354px; padding: 1rem 1.5rem 1.25rem 30px;"
>
  <div class="flex items-center gap-5 mb-1 flex-wrap">
    <a href="/about" class="text-[var(--color-text-primary)] hover:opacity-70 transition-opacity" style="font-family: var(--font-body); font-size: 14px; font-weight: 700;">About</a>
    <a href="/contact" class="text-[var(--color-text-primary)] hover:opacity-70 transition-opacity" style="font-family: var(--font-body); font-size: 14px; font-weight: 700;">Contact</a>
    <a href="/privacy" class="text-[var(--color-text-primary)] hover:opacity-70 transition-opacity" style="font-family: var(--font-body); font-size: 14px; font-weight: 700;">Privacy</a>
  </div>
  <p style="font-family: var(--font-body); font-size: 14px; font-weight: 500; color: var(--color-text-secondary);">
    {new Date().getFullYear()} GoinAtlas. All rights reserved.
  </p>
</div>
