---
const destinations = [
  { label: 'Japan', slug: 'japan' },
  { label: 'South Korea', slug: 'korea' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white border-b border-[var(--color-border)] sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between gap-4">
    <!-- Logo -->
    <a href="/" class="flex items-center flex-shrink-0">
      <img src="/images/logo.svg" alt="GoinAtlas" class="h-6 w-auto" />
    </a>

    <!-- Nav -->
    <nav class="hidden md:flex items-center gap-8 flex-1 justify-center">
      {destinations.map((dest) => (
        <a
          href={`/${dest.slug}`}
          class:list={[
            "text-sm font-medium transition-colors",
            currentPath.startsWith(`/${dest.slug}`)
              ? "text-[var(--color-brand-600)]"
              : "text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]"
          ]}
        >
          {dest.label}
        </a>
      ))}
    </nav>

    <!-- Right: Search + mobile menu -->
    <div class="flex items-center gap-3 flex-shrink-0">
      <!-- Search trigger -->
      <button
        id="header-search-btn"
        class="p-2 text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors"
        aria-label="Search guides"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
      </button>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-[var(--color-text-secondary)]"
        aria-label="Open menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Search overlay (full-width, drops below header) -->
  <div id="header-search-overlay" class="hidden border-t border-[var(--color-border)] bg-white px-6 py-3">
    <div class="max-w-2xl mx-auto relative">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-[var(--color-text-muted)] w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        id="header-search-input"
        type="text"
        placeholder="Search guides… Japan, Korea, food, itinerary…"
        autocomplete="off"
        class="w-full pl-9 pr-10 py-2.5 text-sm bg-[var(--color-bg)] border border-[var(--color-border)] rounded-xl focus:outline-none focus:border-[var(--color-brand-600)] transition-colors"
      />
      <button id="header-search-close" class="absolute right-3 top-1/2 -translate-y-1/2 text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)]">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <!-- Autocomplete dropdown -->
    <div id="header-search-results" class="max-w-2xl mx-auto hidden mt-1 bg-white border border-[var(--color-border)] rounded-xl shadow-lg overflow-hidden divide-y divide-[var(--color-border)]">
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-[var(--color-border)] bg-white px-6 py-4">
    {destinations.map((dest) => (
      <a
        href={`/${dest.slug}`}
        class="block py-3 text-sm font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-brand-600)] border-b border-[var(--color-border)]"
      >
        {dest.label}
      </a>
    ))}
  </div>
</header>

<script>
  // Mobile menu
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  mobileBtn?.addEventListener('click', () => mobileMenu?.classList.toggle('hidden'));

  // Search overlay
  const searchBtn = document.getElementById('header-search-btn');
  const searchClose = document.getElementById('header-search-close');
  const searchOverlay = document.getElementById('header-search-overlay');
  const searchInput = document.getElementById('header-search-input') as HTMLInputElement;
  const searchResults = document.getElementById('header-search-results');

  let allArticles: Array<{ title: string; slug: string; destination: string; category: string; description: string }> = [];

  function openSearch() {
    searchOverlay?.classList.remove('hidden');
    setTimeout(() => searchInput?.focus(), 50);
  }
  function closeSearch() {
    searchOverlay?.classList.add('hidden');
    if (searchResults) searchResults.classList.add('hidden');
    if (searchInput) searchInput.value = '';
  }

  searchBtn?.addEventListener('click', openSearch);
  searchClose?.addEventListener('click', closeSearch);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSearch();
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
  });

  // Lazy-load article data on first search interaction
  let dataLoaded = false;
  async function loadArticles() {
    if (dataLoaded) return;
    try {
      const res = await fetch('/search.json');
      allArticles = await res.json();
      dataLoaded = true;
    } catch {}
  }

  searchBtn?.addEventListener('click', loadArticles);

  function renderResults(query: string) {
    if (!searchResults) return;
    if (!query.trim()) { searchResults.classList.add('hidden'); return; }
    const q = query.toLowerCase();
    const matches = allArticles.filter(
      (a) => a.title.toLowerCase().includes(q) || a.description.toLowerCase().includes(q) || a.category.toLowerCase().includes(q)
    ).slice(0, 6);
    if (!matches.length) { searchResults.classList.add('hidden'); return; }
    searchResults.innerHTML = matches.map((a) => `
      <a href="/${a.destination.toLowerCase()}/${a.slug}" class="flex items-center gap-3 px-4 py-3 hover:bg-[var(--color-bg)] transition-colors group">
        <span class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand-600)] bg-[var(--color-brand-50)] px-2 py-0.5 rounded-full flex-shrink-0">${a.category}</span>
        <div class="min-w-0">
          <p class="text-sm font-medium text-[var(--color-text-primary)] truncate">${a.title}</p>
          <p class="text-xs text-[var(--color-text-muted)] truncate">${a.destination}</p>
        </div>
      </a>
    `).join('');
    searchResults.classList.remove('hidden');
  }

  searchInput?.addEventListener('input', (e) => renderResults((e.target as HTMLInputElement).value));
  searchInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const q = searchInput.value.trim();
      if (q) { window.location.href = `/?q=${encodeURIComponent(q)}`; }
    }
  });
</script>
