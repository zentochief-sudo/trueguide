---
// Header — thin nav bar (4rem / 64px), Medium-style
// Sidebar toggle dispatches goinatlas:toggleSidebar
---

<header
  class="bg-white border-b border-[var(--color-border)] sticky top-0 z-50"
  id="site-header"
  style="height: 4rem;"
>
  <div class="h-full flex items-center" style="padding-right: 1rem;">

    <!-- Left section: fixed width = sidebar width (240px) so search aligns with content -->
    <div class="flex items-center gap-2 flex-shrink-0 px-3 hdr-left">
      <!-- Hamburger: shown when sidebar is CLOSED -->
      <button
        id="sidebar-toggle-btn"
        class="hdr-toggle-btn p-2 rounded-lg flex-shrink-0"
        aria-label="Open sidebar"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>

      <!-- Logo -->
      <a href="/" class="flex items-center flex-shrink-0" id="header-logo">
        <img src="/images/logo.svg" alt="GoinAtlas" class="h-5 w-auto" />
      </a>

      <!-- Collapse btn: shown when sidebar is OPEN -->
      <button
        id="sidebar-collapse-btn"
        class="hdr-toggle-btn p-2 rounded-lg flex-shrink-0"
        aria-label="Close sidebar"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11 17l-5-5 5-5"/>
          <path d="M18 17l-5-5 5-5"/>
        </svg>
      </button>
    </div>

    <!-- Search bar starts exactly at sidebar end -->
    <div class="flex-1 relative max-w-md" id="header-search-wrapper">
      <svg
        class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[var(--color-text-muted)] pointer-events-none"
        fill="none" stroke="currentColor" viewBox="0 0 24 24"
      >
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        id="header-search-input"
        type="text"
        autocomplete="off"
        spellcheck="false"
        placeholder=""
        class="w-full pl-9 pr-4 py-2 text-sm bg-white border border-[var(--color-brand-600)] rounded-full text-[var(--color-text-primary)] placeholder-[var(--color-text-secondary)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-600)] transition-colors"
      />
      <div
        id="header-search-results"
        class="hidden absolute left-0 right-0 top-full mt-1.5 bg-white border border-[var(--color-border)] rounded-xl shadow-lg overflow-hidden z-50"
      ></div>
    </div>

    <!-- Right: language + profile (hidden on mobile — moved to sidebar footer) -->
    <div class="flex items-center gap-2 flex-shrink-0 ml-auto" id="header-right-section">

      <!-- Profile button -->
      <button
        id="profile-btn"
        class="flex items-center justify-center w-8 h-8 rounded-full bg-[var(--color-brand-50)] text-[var(--color-brand-600)] hover:bg-[var(--color-brand-100)] transition-colors"
        aria-label="Profile"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 12a3 3 0 100-6 3 3 0 000 6z"/>
          <path fill-rule="evenodd" d="M12 18c-4.418 0-8-1.79-8-4s3.582-4 8-4 8 1.79 8 4-3.582 4-8 4z" clip-rule="evenodd"/>
        </svg>
      </button>

      <!-- Language -->
      <div class="relative" id="lang-dropdown-wrapper">
        <button
          id="lang-btn"
          class="flex items-center gap-1 px-2.5 py-1.5 text-xs font-semibold text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] border border-[var(--color-border)] rounded-full transition-colors"
          aria-label="Language"
        >
          <span id="lang-current">EN</span>
          <svg class="w-3 h-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div id="lang-menu" class="hidden absolute right-0 top-full mt-1 bg-white border border-[var(--color-border)] rounded-xl shadow-lg overflow-hidden min-w-[80px] z-50">
          <button class="w-full px-4 py-2.5 text-xs font-semibold text-left text-[var(--color-brand-700)] bg-[var(--color-brand-50)]">EN</button>
        </div>
      </div>

    </div>
  </div>
</header>

<style>
  /* Left section fixed width on desktop */
  .hdr-left { width: 240px; }

  /* ── Mobile (< 768px): hide right section entirely, collapse left section ── */
  @media (max-width: 767px) {
    .hdr-left { width: auto !important; }
    #header-right-section { display: none !important; }
  }

  /* Both toggle buttons — light style, smooth slide-in/out */
  .hdr-toggle-btn {
    color: var(--color-text-secondary);
    transition: color 0.15s, background 0.15s, opacity 0.18s ease, max-width 0.18s ease, padding 0.18s ease;
    overflow: hidden;
  }
  .hdr-toggle-btn:hover {
    color: var(--color-text-primary);
    background: var(--color-bg-subtle);
  }

  /* Hamburger: visible by default */
  #sidebar-toggle-btn {
    max-width: 40px;
    opacity: 1;
    pointer-events: auto;
  }
  /* Collapse: hidden by default (after the logo) */
  #sidebar-collapse-btn {
    max-width: 0;
    opacity: 0;
    padding-left: 0;
    padding-right: 0;
    pointer-events: none;
  }

  /* When sidebar is open: swap */
  #site-header.sidebar-is-open #sidebar-toggle-btn {
    max-width: 0;
    opacity: 0;
    padding-left: 0;
    padding-right: 0;
    pointer-events: none;
  }
  #site-header.sidebar-is-open #sidebar-collapse-btn {
    max-width: 40px;
    opacity: 1;
    padding-left: 0.5rem;
    padding-right: 0.5rem;
    pointer-events: auto;
  }
</style>

<script>
  // ── --header-h: just the nav bar height (4rem = 64px) ────────
  document.documentElement.style.setProperty('--header-h', '4rem');

  // ── Sidebar toggle — two-button approach ─────────────────────
  const header = document.getElementById('site-header');

  // Mirror GlobalSidebar's initial-state logic
  const stored = localStorage.getItem('goinatlas:sidebar-collapsed');
  let sidebarOpen = window.innerWidth < 768 ? false : stored !== '1';

  function syncHeader() {
    header?.classList.toggle('sidebar-is-open', sidebarOpen);
  }
  // Head script already set the correct visual state before paint.
  // Just sync the class so JS-driven toggles work correctly afterward.
  syncHeader();

  document.addEventListener('goinatlas:sidebarChanged', ((e: CustomEvent) => {
    sidebarOpen = !e.detail.collapsed;
    syncHeader();
  }) as EventListener);

  // Both buttons dispatch the same toggle event
  document.getElementById('sidebar-toggle-btn')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('goinatlas:toggleSidebar'));
  });
  document.getElementById('sidebar-collapse-btn')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('goinatlas:toggleSidebar'));
  });

  // ── Language dropdown ─────────────────────────────────────────
  const langBtn  = document.getElementById('lang-btn');
  const langMenu = document.getElementById('lang-menu');
  langBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    langMenu?.classList.toggle('hidden');
  });
  document.addEventListener('click', () => langMenu?.classList.add('hidden'));

  // ── Search ────────────────────────────────────────────────────
  const input   = document.getElementById('header-search-input') as HTMLInputElement;
  const results = document.getElementById('header-search-results');

  const placeholders = [
    'Search guides...',
    'Japan 2-week itinerary...',
    'Best time to visit Seoul...',
    'Hidden gems in Tokyo...',
    'South Korea food guide...',
  ];

  // State machine: typing → hold → deleting → gap → typing …
  type PhState = 'typing' | 'hold' | 'deleting' | 'gap';
  // Pick a random phrase and show it FULLY on page load — no typing animation on first render
  let phIdx   = Math.floor(Math.random() * placeholders.length);
  let phChar  = placeholders[phIdx].length;
  let phState: PhState = 'hold'; // already fully typed → hold, then cycle normally

  // Set immediately so the HTML placeholder="Search guides..." never shows
  if (input) input.setAttribute('placeholder', placeholders[phIdx]);

  function typewriterStep() {
    if (document.activeElement === input || input.value) {
      setTimeout(typewriterStep, 300);
      return;
    }

    const line = placeholders[phIdx];

    if (phState === 'typing') {
      phChar++;
      input.setAttribute('placeholder', line.slice(0, phChar) + (phChar < line.length ? '|' : ''));
      if (phChar >= line.length) {
        // Finished typing — hold for 5 s
        phState = 'hold';
        setTimeout(typewriterStep, 5000);
      } else {
        setTimeout(typewriterStep, 30);
      }

    } else if (phState === 'hold') {
      // Pause over — start deleting
      phState = 'deleting';
      setTimeout(typewriterStep, 16);

    } else if (phState === 'deleting') {
      phChar--;
      input.setAttribute('placeholder', phChar > 0 ? line.slice(0, phChar) + '|' : '');
      if (phChar <= 0) {
        phIdx = (phIdx + 1) % placeholders.length;
        phChar = 0;
        phState = 'gap';
        setTimeout(typewriterStep, 500); // short pause before next phrase
      } else {
        setTimeout(typewriterStep, 16);
      }

    } else if (phState === 'gap') {
      phState = 'typing';
      setTimeout(typewriterStep, 30);
    }
  }
  typewriterStep();

  type Article = { title: string; slug: string; destination: string; category: string; description: string };
  let articles: Article[] = [];
  let loaded = false;
  let scopedDestination: string | null = null;

  async function loadArticles() {
    if (loaded) return;
    try { const res = await fetch('/search.json'); articles = await res.json(); loaded = true; } catch {}
  }

  document.addEventListener('goinatlas:searchScope', ((e: CustomEvent) => {
    scopedDestination = e.detail.destination ?? null;
  }) as EventListener);

  function renderResults(query: string) {
    if (!results) return;
    if (!query.trim()) { results.classList.add('hidden'); return; }
    const q = query.toLowerCase();
    let pool = scopedDestination
      ? articles.filter((a) => a.destination.toLowerCase() === scopedDestination!.toLowerCase())
      : articles;
    const matches = pool.filter(
      (a) => a.title.toLowerCase().includes(q) || a.description.toLowerCase().includes(q) || a.category.toLowerCase().includes(q)
    ).slice(0, 6);
    if (!matches.length) { results.classList.add('hidden'); return; }
    results.innerHTML = matches.map((a) => `
      <a href="/${a.destination.toLowerCase()}/${a.slug}"
        class="flex items-center gap-3 px-4 py-3 hover:bg-[var(--color-bg-subtle)] transition-colors border-b border-[var(--color-border)] last:border-0">
        <span class="text-[10px] font-semibold uppercase tracking-wider text-[var(--color-brand-700)] bg-[var(--color-brand-50)] px-2 py-0.5 rounded-full flex-shrink-0">${a.category}</span>
        <div class="min-w-0">
          <p class="text-sm font-medium text-[var(--color-text-primary)] truncate">${a.title}</p>
          <p class="text-xs text-[var(--color-text-muted)] truncate">${a.destination}</p>
        </div>
      </a>
    `).join('');
    results.classList.remove('hidden');
  }

  input?.addEventListener('focus', loadArticles);
  input?.addEventListener('input', (e) => {
    loadArticles();
    renderResults((e.target as HTMLInputElement).value);
  });
  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') { input.value = ''; results?.classList.add('hidden'); input.blur(); }
    if (e.key === 'Enter' && input.value.trim())
      window.location.href = `/?q=${encodeURIComponent(input.value.trim())}`;
  });
  document.addEventListener('click', (e) => {
    if (!document.getElementById('header-search-wrapper')?.contains(e.target as Node))
      results?.classList.add('hidden');
  });
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); input?.focus(); }
  });
</script>
