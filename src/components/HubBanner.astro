---
// HubBanner — Medium-style newsletter banner
// Placed in center column only, sticky, no dismiss button
---

<div
  id="hub-banner"
  class="shrink-0 border-b border-[var(--color-border)] bg-[var(--color-bg-subtle)] py-4 px-5 flex items-center gap-3"
>
  <svg class="w-4 h-4 text-[var(--color-brand-600)] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
    <rect x="2" y="4" width="20" height="16" rx="2"/>
    <path d="M2 7l10 7 10-7"/>
  </svg>
  <p class="text-sm text-[var(--color-text-secondary)]">
    Deep travel guides for Japan, South Korea and beyond — curated weekly.
    <a
      href="#newsletter"
      class="font-semibold text-[var(--color-text-primary)] underline underline-offset-2 hover:text-[var(--color-brand-600)] transition-colors ml-1"
    >
      Subscribe free →
    </a>
  </p>
</div>

