---
interface Props {
  destination?: string; // If provided, shows destination-specific copy
}

const { destination } = Astro.props;

const title = destination
  ? `Get the best ${destination} guides in your inbox`
  : 'Discover more. One destination at a time.';

const description = destination
  ? `New articles, hidden spots and travel tips for ${destination} — straight to you, no spam.`
  : 'New deep guides every week. Choose the destinations you care about.';
---

<div id="newsletter" class="bg-[var(--color-brand-50)] border border-[var(--color-brand-100)] rounded-2xl p-8">
  <div class="max-w-xl">
    <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-brand-600)] mb-2">Newsletter</p>
    <h3 class="text-xl font-bold text-[var(--color-text-primary)] mb-2" style="font-family: var(--font-editorial)">
      {title}
    </h3>
    <p class="text-sm text-[var(--color-text-secondary)] mb-6 leading-relaxed">
      {description}
    </p>

    <!-- Beehiiv embed placeholder — replace with actual embed code from Beehiiv dashboard -->
    <form class="flex flex-col sm:flex-row gap-3" id="newsletter-form">
      <input
        type="email"
        name="email"
        placeholder="your@email.com"
        required
        class="flex-1 px-4 py-2.5 rounded-lg border border-[var(--color-border)] bg-white text-sm focus:outline-none focus:border-[var(--color-brand-500)] focus:ring-2 focus:ring-[var(--color-brand-100)]"
      />
      <button
        type="submit"
        class="bg-[var(--color-brand-600)] hover:bg-[var(--color-brand-700)] text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition-colors whitespace-nowrap"
      >
        Subscribe →
      </button>
    </form>
    <p class="text-xs text-[var(--color-text-muted)] mt-3">No spam. Unsubscribe anytime.</p>
  </div>
</div>

