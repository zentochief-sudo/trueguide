---
// PageSkeleton — shown during page navigation (astro:before-preparation → astro:page-load).
// Includes two skeleton types:
//   [data-sk="article"] → for /{dest}/{slug} pages
//   [data-sk="hub"]     → for / and /{dest} pages
// JS in BaseLayout detects destination URL and shows the correct one.
---

<!-- ── Article skeleton ──────────────────────────────────── -->
<div id="page-skeleton" data-sk="article" aria-hidden="true">

  <!-- Hero -->
  <div class="sk-hero sk-shimmer"></div>

  <!-- Breadcrumb bar -->
  <div class="sk-breadcrumb">
    <div class="sk-line sk-shimmer" style="width:260px; height:13px;"></div>
  </div>

  <!-- 3-column grid -->
  <div class="sk-grid sk-grid--article">

    <!-- Left: TOC -->
    <div class="sk-toc">
      <div class="sk-line sk-shimmer" style="width:58px; height:13px; margin-bottom:14px;"></div>
      <div class="sk-line sk-shimmer" style="width:148px;"></div>
      <div class="sk-line sk-shimmer" style="width:124px;"></div>
      <div class="sk-line sk-shimmer" style="width:162px;"></div>
      <div class="sk-line sk-shimmer" style="width:108px;"></div>
      <div class="sk-line sk-shimmer" style="width:140px;"></div>
      <div class="sk-line sk-shimmer" style="width:96px;"></div>
    </div>

    <!-- Center: content -->
    <div class="sk-content">
      <div class="sk-line sk-shimmer" style="width:88%; height:38px; margin-bottom:8px;"></div>
      <div class="sk-line sk-shimmer" style="width:64%; height:38px; margin-bottom:32px;"></div>
      <div class="sk-block sk-shimmer" style="height:90px; margin-bottom:28px;"></div>
      <div class="sk-line sk-shimmer" style="width:100%;"></div>
      <div class="sk-line sk-shimmer" style="width:96%;"></div>
      <div class="sk-line sk-shimmer" style="width:88%;"></div>
      <div class="sk-line sk-shimmer" style="width:100%;"></div>
      <div class="sk-line sk-shimmer" style="width:72%;"></div>
      <div class="sk-line sk-shimmer" style="width:100%; margin-top:20px;"></div>
      <div class="sk-line sk-shimmer" style="width:91%;"></div>
      <div class="sk-line sk-shimmer" style="width:78%;"></div>
      <div class="sk-line sk-shimmer" style="width:100%;"></div>
      <div class="sk-line sk-shimmer" style="width:60%;"></div>
    </div>

    <!-- Right: rail -->
    <div class="sk-rail">
      <div class="sk-block sk-shimmer" style="height:110px; margin-bottom:12px;"></div>
      <div class="sk-block sk-shimmer" style="height:200px; margin-bottom:12px;"></div>
      <div class="sk-block sk-shimmer" style="height:200px;"></div>
    </div>

  </div>
</div>

<!-- ── Hub / Home skeleton ────────────────────────────────── -->
<div id="page-skeleton-hub" data-sk="hub" aria-hidden="true">

  <!-- Banner -->
  <div class="sk-banner sk-shimmer"></div>

  <!-- 2-column layout: feed + rail -->
  <div class="sk-grid sk-grid--hub">

    <!-- Feed column -->
    <div class="sk-feed">

      <!-- Tabs row -->
      <div class="sk-tabs">
        <div class="sk-tab-pill sk-shimmer" style="width:72px;"></div>
        <div class="sk-tab-pill sk-shimmer" style="width:88px;"></div>
        <div class="sk-tab-pill sk-shimmer" style="width:104px;"></div>
      </div>

      <!-- Article cards -->
      {Array.from({ length: 7 }).map(() => (
        <div class="sk-card">
          <div class="sk-card-thumb sk-shimmer"></div>
          <div class="sk-card-body">
            <div class="sk-line sk-shimmer" style="width:80%; height:15px; margin-bottom:6px;"></div>
            <div class="sk-line sk-shimmer" style="width:55%; height:13px; margin-bottom:10px;"></div>
            <div class="sk-line sk-shimmer" style="width:100%; height:12px;"></div>
            <div class="sk-line sk-shimmer" style="width:90%; height:12px;"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Right rail -->
    <div class="sk-rail sk-rail--hub">
      <div class="sk-block sk-shimmer" style="height:240px; margin-bottom:12px;"></div>
      <div class="sk-block sk-shimmer" style="height:200px; margin-bottom:12px;"></div>
      <div class="sk-block sk-shimmer" style="height:180px;"></div>
    </div>

  </div>
</div>

<style>
  /* ── Shimmer keyframe ──────────────────────────────────── */
  @keyframes sk-sweep {
    0%   { background-position: -600px 0; }
    100% { background-position: 600px 0; }
  }

  .sk-shimmer {
    background: linear-gradient(
      90deg,
      var(--sk-base, #ebebeb) 25%,
      var(--sk-shine, #f5f5f5) 37%,
      var(--sk-base, #ebebeb) 63%
    );
    background-size: 1200px 100%;
    animation: sk-sweep 1.6s ease-in-out infinite;
    border-radius: 6px;
  }

  /* ── Wrapper shared ────────────────────────────────────── */
  #page-skeleton,
  #page-skeleton-hub {
    display: none;
    position: absolute;
    inset: 0;
    z-index: 200;
    background: var(--color-bg, #fff);
    overflow: hidden;
    pointer-events: none;
  }

  /* ════════════════════════════════════════════════════════ */
  /* ARTICLE skeleton                                         */
  /* ════════════════════════════════════════════════════════ */

  .sk-hero {
    width: 100%;
    height: clamp(240px, 40vh, 420px);
    border-radius: 0;
  }

  .sk-breadcrumb {
    height: 2.75rem;
    display: flex;
    align-items: center;
    padding: 0 1.5rem;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
  }

  .sk-grid--article {
    display: grid;
    grid-template-columns: 1fr min(680px, 100%) 1fr;
    padding: 2.5rem 0;
  }

  .sk-toc {
    display: none;
    padding: 0 1.5rem 0 0;
    justify-self: end;
    width: 220px;
  }
  @media (min-width: 1280px) {
    .sk-toc { display: block; }
  }

  .sk-content {
    padding: 0 2rem;
    min-width: 0;
  }

  .sk-rail {
    display: none;
    padding: 0 0 0 1.5rem;
  }
  @media (min-width: 1280px) {
    .sk-rail { display: block; }
  }

  /* ════════════════════════════════════════════════════════ */
  /* HUB / HOME skeleton                                      */
  /* ════════════════════════════════════════════════════════ */

  .sk-banner {
    width: 100%;
    height: 2.5rem;
    border-radius: 0;
    margin-bottom: 0;
  }

  .sk-grid--hub {
    display: flex;
    height: calc(100vh - 4rem - 2.5rem);
    overflow: hidden;
  }

  /* Feed */
  .sk-feed {
    flex: 1;
    min-width: 0;
    padding: 1.5rem 1.5rem 0;
    overflow: hidden;
  }

  .sk-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
  }

  .sk-tab-pill {
    height: 28px;
    border-radius: 6px;
  }

  /* Article card */
  .sk-card {
    display: flex;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
  }

  .sk-card-thumb {
    width: 88px;
    height: 66px;
    flex-shrink: 0;
    border-radius: 8px;
  }

  .sk-card-body {
    flex: 1;
    min-width: 0;
    padding-top: 2px;
  }

  /* Right rail - hub */
  .sk-rail--hub {
    display: none;
    width: 300px;
    flex-shrink: 0;
    padding: 1.5rem 1.5rem 0;
  }
  @media (min-width: 1280px) {
    .sk-rail--hub { display: block; }
  }

  /* ── Atoms ─────────────────────────────────────────────── */
  .sk-line {
    height: 14px;
    margin-bottom: 10px;
  }
  .sk-block {
    width: 100%;
    border-radius: 8px;
  }
</style>
