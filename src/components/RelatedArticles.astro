---
import type { RelatedArticle } from '../lib/related-articles';

interface Props {
  articles: RelatedArticle[];
  destination: string;
}

const { articles, destination } = Astro.props;

const destPath = destination === 'South Korea' ? 'korea'
  : destination === 'Costa Rica' ? 'costa-rica'
  : destination === 'Réunion' ? 'reunion'
  : destination.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
---

{articles.length > 0 && (
  <section class="related-articles">
    <h2 class="related-title">Keep reading</h2>
    <div class="related-list">
      {articles.map((a) => (
        <a href={a.href} class="related-card group">
          <div class="related-img-wrap">
            {a.heroImage ? (
              <img src={a.heroImage} alt={a.title} loading="lazy" decoding="async" class="related-img group-hover:scale-105 transition-transform duration-300" />
            ) : (
              <div class="related-img-placeholder">
                <svg width="24" height="24" fill="none" stroke="#d4d4d4" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </div>
            )}
          </div>
          <div class="related-body">
            <span class="related-category">{a.category}</span>
            <h3 class="related-card-title group-hover:text-[var(--color-brand-600)] transition-colors">{a.title}</h3>
            <span class="related-meta">{a.readingTime} min read →</span>
          </div>
        </a>
      ))}
    </div>
    <a href={`/${destPath}`} class="related-see-all">
      See all {destination} guides →
    </a>
  </section>
)}

<style>
  .related-articles {
    border-top: 1px solid var(--color-border);
    padding-top: 2rem;
    margin-top: 2rem;
  }
  .related-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 1.25rem 0;
  }
  .related-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .related-card {
    display: flex;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    cursor: pointer;
  }
  .related-card:last-child {
    border-bottom: none;
  }
  .related-img-wrap {
    flex-shrink: 0;
    width: 120px;
    height: 80px;
    border-radius: 4px;
    overflow: hidden;
    background: #f5f5f5;
  }
  .related-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .related-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f5f5;
  }
  .related-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .related-category {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-brand-600);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-family: var(--font-body);
  }
  .related-card-title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.3;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .related-meta {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-family: var(--font-body);
    margin-top: auto;
  }
  .related-see-all {
    display: inline-block;
    margin-top: 1.25rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text-primary);
    text-decoration: underline;
    font-family: var(--font-body);
  }
  .related-see-all:hover {
    color: var(--color-brand-600);
  }
</style>
