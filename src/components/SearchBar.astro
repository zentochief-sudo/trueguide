---
interface Props {
  destination?: string;
  variant?: 'hero' | 'compact';
}

const { destination, variant = 'hero' } = Astro.props;

const homePlaceholders = [
  'Where are you headed?',
  'Japan 2-week itinerary...',
  'Best time to visit Seoul...',
  'Hidden gems in Tokyo...',
  'Off the beaten path in Japan...',
  'South Korea food guide...',
  'Find your next trip...',
];

const japanPlaceholders = [
  'Search Japan guides...',
  '2-week Japan itinerary...',
  'JR Pass — worth it?',
  'Best hidden spots in Japan...',
  'Cherry blossom guide...',
  'Kanazawa travel tips...',
];

const koreaPlaceholders = [
  'Search South Korea guides...',
  'Seoul food guide...',
  'Best time to visit Korea...',
  'Busan travel tips...',
  'Korean temple stay...',
];

const placeholderMap: Record<string, string[]> = {
  japan: japanPlaceholders,
  korea: koreaPlaceholders,
};

const placeholders = destination
  ? (placeholderMap[destination.toLowerCase()] ?? homePlaceholders)
  : homePlaceholders;

const isHero = variant === 'hero';
---

<div
  class={`search-bar-wrapper relative ${isHero ? 'w-full max-w-2xl mx-auto' : 'w-full max-w-sm'}`}
  data-search-bar
  data-destination={destination ?? 'all'}
>
  <div class="relative flex items-center">
    <svg
      class={`absolute left-4 pointer-events-none flex-shrink-0 ${isHero ? 'w-5 h-5 text-white/50' : 'w-4 h-4 text-[var(--color-text-muted)]'}`}
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    <input
      type="text"
      autocomplete="off"
      spellcheck="false"
      data-search-input
      data-placeholders={JSON.stringify(placeholders)}
      placeholder={placeholders[0]}
      class={isHero
        ? 'w-full pl-12 pr-5 py-4 bg-white/10 border border-white/20 backdrop-blur-sm text-white placeholder-white/40 rounded-2xl text-base focus:outline-none focus:bg-white/15 focus:border-white/40 transition-all'
        : 'w-full pl-10 pr-4 py-2.5 bg-white border border-[var(--color-border)] text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] rounded-xl text-sm focus:outline-none focus:border-[var(--color-brand-600)] focus:ring-2 focus:ring-[var(--color-brand-100)] transition-all'
      }
    />
  </div>
</div>

<script>
  document.querySelectorAll('[data-search-bar]').forEach((wrapper) => {
    const input = wrapper.querySelector('[data-search-input]') as HTMLInputElement | null;
    if (!input) return;

    const placeholders = JSON.parse(input.dataset.placeholders ?? '[]') as string[];
    let idx = 0;

    const interval = setInterval(() => {
      idx = (idx + 1) % placeholders.length;
      // Only rotate when empty and not focused
      if (!input.value && document.activeElement !== input) {
        input.setAttribute('placeholder', placeholders[idx]);
      }
    }, 2800);

    input.addEventListener('focus', () => clearInterval(interval), { once: true });

    input.addEventListener('input', () => {
      const query = input.value.toLowerCase().trim();
      document.dispatchEvent(
        new CustomEvent('trueguide:search', {
          detail: { query, destination: (wrapper as HTMLElement).dataset.destination },
          bubbles: true,
        })
      );
    });
  });
</script>
