---
// StaffPicks — right sidebar component
// Shows 3 featured articles (passed from hub page)

interface Pick {
  title: string;
  description: string;
  slug: string;
  destination: string;
  heroImage?: string;
  category: string;
  readingTime: number;
}

interface Props {
  picks: Pick[];
}

const { picks } = Astro.props;
---

<div>
  <h3 class="text-sm font-semibold text-[var(--color-text-primary)] mb-4 uppercase tracking-widest">
    Staff Picks
  </h3>
  <div class="space-y-5">
    {picks.map((article) => (
      <a
        href={`/${article.destination.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g,'').replace(/\s+/g,'-').replace(/[^a-z0-9-]/g,'')}/${article.slug}`}
        class="flex gap-3 group"
      >
        {article.heroImage ? (
          <div class="w-14 h-14 rounded-lg overflow-hidden shrink-0 bg-gray-100">
            <img
              src={article.heroImage}
              alt={article.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            />
          </div>
        ) : (
          <div class="w-14 h-14 rounded-lg shrink-0 bg-[var(--color-brand-50)] flex items-center justify-center">
            <span class="text-[var(--color-brand-400)] text-lg">✦</span>
          </div>
        )}
        <div class="min-w-0">
          <span class="text-[10px] font-semibold text-[var(--color-brand-600)] uppercase tracking-wider">
            {article.category}
          </span>
          <p class="text-sm font-medium text-[var(--color-text-primary)] leading-snug line-clamp-2 group-hover:text-[var(--color-brand-600)] transition-colors mt-0.5">
            {article.title}
          </p>
          <p class="text-xs text-[var(--color-text-muted)] mt-1">{article.readingTime} min read</p>
        </div>
      </a>
    ))}
  </div>
</div>
