---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{filtered.length > 1 && (
  <nav data-toc aria-label="Table of contents">
    <p class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-text-muted)] mb-4 px-1">
      Contents
    </p>
    <ul class="space-y-0.5">
      {filtered.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            data-toc-link={heading.slug}
            class={[
              'block text-sm leading-snug py-1.5 px-3 rounded-lg transition-all',
              'text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-brand-50)]',
              heading.depth === 3 ? 'pl-6 text-xs' : '',
            ].join(' ')}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<script>
  const tocLinks = document.querySelectorAll('[data-toc-link]');
  if (tocLinks.length === 0) {
    // nothing to do
  } else {
    // Smooth scroll on click
    tocLinks.forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const slug = (link as HTMLElement).dataset.tocLink!;
        const target = document.getElementById(slug);
        if (target) {
          const offset = 88; // account for sticky header
          const top = target.getBoundingClientRect().top + window.scrollY - offset;
          window.scrollTo({ top, behavior: 'smooth' });
        }
      });
    });

    // Scroll-spy with IntersectionObserver
    const headingEls = Array.from(tocLinks)
      .map((link) => document.getElementById((link as HTMLElement).dataset.tocLink!))
      .filter(Boolean) as HTMLElement[];

    let activeSlug: string | null = null;

    function setActive(slug: string | null) {
      if (slug === activeSlug) return;
      activeSlug = slug;
      tocLinks.forEach((link) => {
        const el = link as HTMLElement;
        const isActive = el.dataset.tocLink === slug;
        el.classList.toggle('!text-[var(--color-brand-600)]', isActive);
        el.classList.toggle('!bg-[var(--color-brand-50)]', isActive);
        el.classList.toggle('font-medium', isActive);
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        // Find the topmost visible heading
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible.length > 0) {
          setActive((visible[0].target as HTMLElement).id);
        }
      },
      { rootMargin: '-80px 0px -60% 0px', threshold: 0 }
    );

    headingEls.forEach((el) => observer.observe(el));
  }
</script>
