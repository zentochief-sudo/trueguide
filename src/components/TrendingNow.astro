---
// Recommended Cities — right sidebar with tagline + city filter
// Dispatches goinatlas:cityFilter; listens to sync state

const cities = [
  { id: 'tokyo', label: '🇯🇵 Tokyo' },
  { id: 'kyoto', label: '🇯🇵 Kyoto' },
  { id: 'osaka', label: '🇯🇵 Osaka' },
  { id: 'kanazawa', label: '🇯🇵 Kanazawa' },
  { id: 'hiroshima', label: '🇯🇵 Hiroshima' },
  { id: 'seoul', label: '🇰🇷 Seoul' },
  { id: 'busan', label: '🇰🇷 Busan' },
  { id: 'gyeongju', label: '🇰🇷 Gyeongju' },
  { id: 'jeju', label: '🇰🇷 Jeju' },
  { id: 'hokkaido', label: '🇯🇵 Hokkaido' },
];
---

<div class="space-y-8">
  <!-- Tagline -->
  <div>
    <p class="leading-relaxed text-[var(--color-text-primary)]" style="font-family: var(--font-body); font-size: 14px; font-weight: 500;">
      No filler, no fluff. Just what you need to discover a place properly.
    </p>
  </div>

  <!-- Cities Section -->
  <div>
    <h3 class="text-xs font-semibold text-[var(--color-text-primary)] mb-3 uppercase tracking-widest">
      Recommended Cities
    </h3>
    <div class="flex flex-wrap gap-2">
      {cities.map((city) => (
        <button
          class="city-btn"
          data-city={city.id}
          data-label={city.label}
        >
          {city.label}<span class="pill-x"> ×</span>
        </button>
      ))}
    </div>
  </div>
</div>

<style>
  /* City pills */
  .city-btn {
    padding: 0.3rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.8rem;
    font-weight: 400;
    border: none;
    background: #f2f2f2;
    color: var(--color-text-primary);
    cursor: pointer;
    transition: background 0.12s, color 0.12s;
    line-height: 1.6;
    white-space: nowrap;
  }
  .city-btn:hover:not(:disabled):not(.is-disabled) {
    background: #e8e8e8;
  }
  .city-btn.is-active {
    background: var(--color-brand-600);
    color: #fff;
    font-weight: 500;
  }
  .city-btn:disabled,
  .city-btn.is-disabled {
    opacity: 0.35;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* × inside active pills */
  .city-btn .pill-x { display: none; }
  .city-btn.is-active .pill-x { display: inline; opacity: 0.7; margin-left: 2px; }
</style>

<script>
  const cityBtns = document.querySelectorAll<HTMLButtonElement>('.city-btn');
  let activeCity: string | null = null;

  cityBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const newCity = btn.dataset.city === activeCity ? null : btn.dataset.city!;
      document.dispatchEvent(
        new CustomEvent('goinatlas:cityFilter', { detail: { city: newCity } })
      );
    });
  });

  document.addEventListener('goinatlas:cityFilter', ((e: CustomEvent) => {
    activeCity = e.detail.city;
    cityBtns.forEach((btn) => {
      btn.classList.toggle('is-active', btn.dataset.city === activeCity);
    });
  }) as EventListener);
</script>
