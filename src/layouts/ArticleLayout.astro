---
import BaseLayout from './BaseLayout.astro';
import EtsyCTA from '../components/EtsyCTA.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import Comments from '../components/Comments.astro';
import TableOfContents from '../components/TableOfContents.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import AdSlot from '../components/AdSlot.astro';
import AdRail from '../components/AdRail.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import BookingCTA from '../components/BookingCTA.astro';
import type { RelatedArticle } from '../lib/related-articles';
import { extractFAQs, buildFAQSchema } from '../lib/faq';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  destination: string;
  category: string;
  publishDate: Date;
  heroImage?: string;
  readingTime: number;
  etsy_template?: { label: string; url: string };
  headings?: Heading[];
  city?: string;
  tocStyle?: 'sticky-scroll' | 'flow';
  relatedArticles?: RelatedArticle[];
  rawBody?: string;
}

const {
  title,
  description,
  destination,
  category,
  publishDate,
  heroImage,
  readingTime,
  etsy_template,
  headings = [],
  city = 'national',
  relatedArticles = [],
  rawBody = '',
} = Astro.props;

const destSlug = destination.toLowerCase().replace(/\s+/g, '-').replace('south-korea', 'korea');

// Derive WebP path for hero image (served if the .webp file exists)
const heroImageWebp = heroImage ? heroImage.replace(/\.(jpe?g|png)$/i, '.webp') : undefined;

const cityLabels: Record<string, string> = {
  tokyo: 'Tokyo', kyoto: 'Kyoto', osaka: 'Osaka', kanazawa: 'Kanazawa',
  hiroshima: 'Hiroshima', nara: 'Nara', hokkaido: 'Hokkaido', fukuoka: 'Fukuoka',
  seoul: 'Seoul', busan: 'Busan', gyeongju: 'Gyeongju', jeju: 'Jeju',
};

const crumbs = [
  { label: 'Home', href: '/' },
  { label: destination, href: `/${destSlug}` },
  ...(city && city !== 'national' ? [{ label: cityLabels[city] ?? city, href: `/${destSlug}?city=${city}` }] : []),
  { label: title },
];

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const hasToc = headings.filter((h) => h.depth === 2 || h.depth === 3).length > 1;

const canonicalURL = `https://goinatlas.com/${destSlug}/${Astro.params.slug ?? ''}`;
const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description,
  datePublished: publishDate.toISOString(),
  dateModified: publishDate.toISOString(),
  author: {
    '@type': 'Person',
    name: 'GoinAtlas Editorial Team',
    url: 'https://goinatlas.com/team',
    worksFor: { '@type': 'Organization', name: 'GoinAtlas', url: 'https://goinatlas.com' },
  },
  publisher: {
    '@type': 'Organization',
    name: 'GoinAtlas',
    url: 'https://goinatlas.com',
    logo: { '@type': 'ImageObject', url: 'https://goinatlas.com/images/logo.svg' },
  },
  url: canonicalURL,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL },
  ...(heroImage ? { image: `https://goinatlas.com${heroImage}` } : {}),
};

// FAQPage schema for Seasonal articles — boosts featured snippets for "when to visit" queries
const faqItems = (category === 'Seasonal' && rawBody) ? extractFAQs(rawBody) : [];
const faqSchema = buildFAQSchema(faqItems);

const articleSchema = faqSchema
  ? { '@context': 'https://schema.org', '@graph': [blogPostingSchema, faqSchema] }
  : blogPostingSchema;

// Breadcrumb bar height — used to offset sticky TOC
const BREADCRUMB_H = '2.75rem';
---

<BaseLayout title={title} description={description} image={heroImage} hideFooter={true} schema={articleSchema} preloadHero={heroImageWebp ?? heroImage}>

  <!-- ── Hero image ───────────────────────────────────────── -->
  <div class="relative w-full overflow-hidden bg-[var(--color-brand-900)]" style="height: clamp(240px, 40vh, 420px);" transition:name={`hero-${Astro.params.slug}`} transition:animate="fade">
    {heroImage && (
      <picture>
        {heroImageWebp && <source srcset={heroImageWebp} type="image/webp" />}
        <img
          src={heroImage}
          alt={title}
          class="w-full h-full object-cover opacity-80"
          fetchpriority="high"
          loading="eager"
          decoding="async"
          width="1200"
          height="630"
          sizes="(max-width: 768px) 100vw, (max-width: 1280px) calc(100vw - 192px), 1088px"
        />
      </picture>
    )}
    <!-- Subtle gradient only at the bottom for the meta pill -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent" />
    <!-- Meta pill: Date · Read time · Category — top-right, mirrored from TOC/breadcrumb left offset -->
    <div class="absolute meta-pill-anchor">
      <div class="inline-flex items-center gap-3 rounded-full text-white/95 text-xs font-medium"
           style="background: rgba(0,0,0,0.38); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); padding: 0.45rem 1.1rem; letter-spacing: 0.02em;">
        <span>{formattedDate}</span>
        <span style="opacity:0.35;">·</span>
        <span>{readingTime} min read</span>
        <span style="opacity:0.35;">·</span>
        <span>{category}</span>
      </div>
    </div>
  </div>

  <!-- ── Sticky breadcrumb bar ─────────────────────────────── -->
  <!-- "Home" starts at the same X axis as the TOC block (both 140px from the sidebar line) -->
  <div
    class="sticky z-[29] border-b border-[var(--color-border)] bg-[var(--color-bg)]"
    style={`top: 4rem; height: ${BREADCRUMB_H};`}
  >
    <div class="h-full flex items-center breadcrumb-indent" style="padding-right: 1.5rem; overflow: hidden;">
      <nav aria-label="Breadcrumb" class="min-w-0 w-full overflow-hidden">
        <ol class="flex items-center gap-1 text-sm overflow-hidden min-w-0" itemscope itemtype="https://schema.org/BreadcrumbList">
          {crumbs.map((crumb, i) => (
            <li
              class={`flex items-center gap-1 ${i === crumbs.length - 1 ? 'min-w-0 overflow-hidden' : 'flex-shrink-0'}`}
              itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem"
            >
              {i > 0 && (
                <svg class="w-3.5 h-3.5 text-[var(--color-text-muted)] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              )}
              {crumb.href ? (
                <a href={crumb.href} itemprop="item" class="text-[var(--color-text-muted)] hover:text-[var(--color-brand-600)] transition-colors font-medium whitespace-nowrap">
                  <span itemprop="name">{crumb.label}</span>
                </a>
              ) : (
                <span itemprop="name" class="text-[var(--color-text-primary)] font-semibold truncate block">
                  {crumb.label}
                </span>
              )}
              <meta itemprop="position" content={String(i + 1)} />
            </li>
          ))}
        </ol>
      </nav>
    </div>
  </div>

  <!--
    ── 3-column grid: [TOC 1fr | article min(680px,100%) | right 1fr]
    Content is always centered — TOC floats in the left 1fr without displacing it.
  -->
  <div class="article-grid" transition:animate="fade">

    <!-- Left: sticky TOC — left-aligned inside the 1fr column at 140px from sidebar -->
    <div class="toc-column flex-col">
      <div
        class="sticky overflow-y-auto"
        style={`top: calc(4rem + ${BREADCRUMB_H}); max-height: calc(100vh - 4rem - ${BREADCRUMB_H}); padding: 2.5rem 0 4rem 0; width: 100%; max-width: 220px;`}
      >
        <!-- TOC index first -->
        <TableOfContents headings={headings} />

        <!-- Action icons row: Save + Share — below TOC, before See all -->
        <div class="flex items-center gap-4 mt-5">

          <!-- Save / bookmark button (icon only) -->
          <button
            data-save-btn={Astro.url.pathname}
            data-save-label="Save"
            class="action-icon-btn save-btn"
            aria-label="Save article for later"
            aria-pressed="false"
            type="button"
          >
            <!-- Outline: save (unsaved state) -->
            <svg class="save-icon-outline" width="22" height="22" viewBox="0 0 62 62" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M2.86 59.0098C4.73 60.9098 7.32 61.9998 9.97 61.9998C11.57 61.9998 13.18 61.5998 14.62 60.8498C14.83 60.7398 15.03 60.6198 15.22 60.4998L26.26 53.2198C26.48 53.0798 26.73 52.9998 26.98 52.9998C27.23 52.9998 27.48 53.0698 27.7 53.2098L38.74 60.4898C38.94 60.6198 39.14 60.7398 39.35 60.8498C40.79 61.5998 42.4 61.9998 44 61.9998C46.65 61.9998 49.24 60.9098 51.11 59.0198C52.75 57.3498 53.76 55.1598 53.94 52.8398C53.97 52.5398 53.99 52.2698 53.99 52.0098V39.0098C53.99 37.3598 52.64 36.0098 50.99 36.0098C49.34 36.0098 47.99 37.3598 47.99 39.0098V52.1398C47.97 52.1998 47.97 52.2698 47.96 52.3298C47.9 53.2698 47.51 54.1298 46.83 54.8098C45.63 56.0298 43.65 56.3398 42.13 55.5398L31.01 48.2098C28.6 46.6298 25.37 46.6298 22.97 48.2098L11.93 55.4898C10.32 56.3398 8.35 56.0298 7.14 54.8098C6.47 54.1298 6.08 53.2698 6.02 52.3298C6.02 52.2698 6.01 52.1998 6 52.1398V52.0098V15.0098C6 11.1498 9.14 8.00977 13 8.00977H20C21.65 8.00977 23 6.65977 23 5.00977C23 3.35977 21.65 2.00977 20 2.00977H13C5.83 2.00977 0 7.83976 0 15.0098V52.0098C0 52.2798 0.0199992 52.5498 0.0499992 52.8098C0.239999 55.1598 1.24 57.3598 2.88 59.0198L2.86 59.0098Z"/>
              <path d="M58.98 11H39.23L45.03 5.2C46.08 4.15 46.28 2.54 45.51 1.38C44.99 0.599999 44.2 0.11 43.29 0.0200005C43.19 0.0200005 43.09 0 42.99 0C42.2 0 41.44 0.309999 40.87 0.879999L35.14 6.61C33.99 7.76 33.15 9.01 32.66 10.32C31.23 14.11 32.14 18.39 34.97 21.23L40.86 27.12C41.49 27.75 42.34 28.07 43.24 27.99C44.14 27.91 44.92 27.46 45.45 26.7C46.27 25.54 46.05 23.82 44.94 22.72L39.22 17H58.97C60.62 17 61.97 15.65 61.97 14C61.97 12.35 60.62 11 58.97 11H58.98Z"/>
            </svg>
            <!-- Filled: save (saved state) -->
            <svg class="save-icon-filled hidden" width="22" height="22" viewBox="0 0 62 62" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M2.86 59.0098C4.73 60.9098 7.32 61.9998 9.97 61.9998C11.57 61.9998 13.18 61.5998 14.62 60.8498C14.83 60.7398 15.03 60.6198 15.22 60.4998L26.26 53.2198C26.48 53.0798 26.73 52.9998 26.98 52.9998C27.23 52.9998 27.48 53.0698 27.7 53.2098L38.74 60.4898C38.94 60.6198 39.14 60.7398 39.35 60.8498C40.79 61.5998 42.4 61.9998 44 61.9998C46.65 61.9998 49.24 60.9098 51.11 59.0198C52.75 57.3498 53.76 55.1598 53.94 52.8398C53.97 52.5398 53.99 52.2698 53.99 52.0098V39.0098C53.99 37.3598 52.64 36.0098 50.99 36.0098C49.34 36.0098 47.99 37.3598 47.99 39.0098V52.1398C47.97 52.1998 47.97 52.2698 47.96 52.3298C47.9 53.2698 47.51 54.1298 46.83 54.8098C45.63 56.0298 43.65 56.3398 42.13 55.5398L31.01 48.2098C28.6 46.6298 25.37 46.6298 22.97 48.2098L11.93 55.4898C10.32 56.3398 8.35 56.0298 7.14 54.8098C6.47 54.1298 6.08 53.2698 6.02 52.3298C6.02 52.2698 6.01 52.1998 6 52.1398V52.0098V15.0098C6 11.1498 9.14 8.00977 13 8.00977H20C21.65 8.00977 23 6.65977 23 5.00977C23 3.35977 21.65 2.00977 20 2.00977H13C5.83 2.00977 0 7.83976 0 15.0098V52.0098C0 52.2798 0.0199992 52.5498 0.0499992 52.8098C0.239999 55.1598 1.24 57.3598 2.88 59.0198L2.86 59.0098Z"/>
              <path d="M58.98 11H39.23L45.03 5.2C46.08 4.15 46.28 2.54 45.51 1.38C44.99 0.599999 44.2 0.11 43.29 0.0200005C43.19 0.0200005 43.09 0 42.99 0C42.2 0 41.44 0.309999 40.87 0.879999L35.14 6.61C33.99 7.76 33.15 9.01 32.66 10.32C31.23 14.11 32.14 18.39 34.97 21.23L40.86 27.12C41.49 27.75 42.34 28.07 43.24 27.99C44.14 27.91 44.92 27.46 45.45 26.7C46.27 25.54 46.05 23.82 44.94 22.72L39.22 17H58.97C60.62 17 61.97 15.65 61.97 14C61.97 12.35 60.62 11 58.97 11H58.98Z"/>
            </svg>
          </button>

          <!-- Share button (icon only) -->
          <button
            data-share-btn={Astro.url.pathname}
            data-share-title={title}
            class="action-icon-btn share-btn"
            aria-label="Share article"
            type="button"
          >
            <svg width="22" height="22" viewBox="0 0 62 60" fill="black" xmlns="http://www.w3.org/2000/svg">
              <path d="M59 54H14C9.59 54 6 50.41 6 46V3C6 1.35 4.65 0 3 0C1.35 0 0 1.35 0 3V46C0 53.72 6.28 60 14 60H59C60.65 60 62 58.65 62 57C62 55.35 60.65 54 59 54Z"/>
              <path d="M17.8799 41.12C19.0099 42.25 20.9899 42.25 22.1199 41.12L46.9999 16.24V31C46.9999 32.65 48.3499 34 49.9999 34C51.6499 34 52.9999 32.65 52.9999 31V17C52.9999 10.93 48.0699 6 41.9999 6H27.9999C26.3499 6 24.9999 7.35 24.9999 9C24.9999 10.65 26.3499 12 27.9999 12H42.7599L17.8799 36.88C16.7099 38.05 16.7099 39.95 17.8799 41.12Z"/>
            </svg>
          </button>

        </div>

        <!-- See all guides link — below icons, no divider -->
        <div class="mt-4">
          <a
            href={`/${destSlug}`}
            class="text-sm text-[var(--color-text-primary)] underline font-semibold"
            style="font-family: var(--font-body);"
          >
            See all {destination} guides
          </a>
        </div>

      </div>
    </div>

    <!-- Center: article content — always centered, independent of TOC -->
    <div class="min-w-0 article-content-col">

      <!-- Article title — top of content column, above prose -->
      <h1 style="font-family: var(--font-display); font-size: clamp(1.6rem, 3vw, 2.6rem); font-weight: 700; line-height: 1.2; color: var(--color-text-primary); margin: 0 0 1rem 0;">
        {title}
      </h1>

      <!-- Author byline — E-E-A-T signal for Google -->
      <div class="flex items-center gap-2 mb-6" style="font-size: 0.8rem; color: var(--color-text-muted);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;opacity:0.6">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
        <span>By <a href="/team" class="font-medium hover:text-[var(--color-brand-600)] transition-colors" style="color:inherit">GoinAtlas Editorial Team</a></span>
        <span style="opacity:0.3;">·</span>
        <span>Updated {publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</span>
      </div>

      {etsy_template && (
        <EtsyCTA label={etsy_template.label} url={etsy_template.url} position="top" />
      )}

      <!-- Booking CTA — above fold on mobile; hidden on desktop (col3 handles it) -->
      <div class="article-booking-inline">
        <BookingCTA destination={destination} />
      </div>

      <!-- Inline ad — visible below 1280px (mobile/tablet, no col3 rail) -->
      <AdSlot variant="article" class="article-inline-ad" />

      <div class="prose">
        <slot />
      </div>

      <!-- Booking CTA — bottom, mobile only -->
      <div class="article-booking-inline">
        <BookingCTA destination={destination} />
      </div>

      {etsy_template && (
        <EtsyCTA label={etsy_template.label} url={etsy_template.url} position="bottom" />
      )}

      {relatedArticles.length > 0 && (
        <div class="mt-12">
          <RelatedArticles articles={relatedArticles} destination={destination} />
        </div>
      )}

      <div class="mt-12">
        <NewsletterSignup destination={destination} />
      </div>

      {/* Comments hidden until non-GitHub solution is in place */}

    </div>

    <!-- Right col: sticky BookingCTA + ad rail — visible at ≥1280px -->
    <div class="article-col3-ads" style="grid-column: 3;">
      <!-- Sticky Travelpayouts widget — follows scroll -->
      <div class="col3-booking-sticky">
        <BookingCTA destination={destination} />
      </div>
      <AdRail count={4} />
    </div>

  </div>

  <!-- ── Mobile TOC — FAB + right-side drawer (hidden on ≥1440px) ── -->
  {hasToc && (
    <div id="mobile-toc-root">
      <!-- Floating button -->
      <button id="mobile-toc-fab" class="mobile-toc-fab" aria-label="Table of contents">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="16" y2="12"/>
          <line x1="3" y1="18" x2="19" y2="18"/>
        </svg>
        <span>Contents</span>
      </button>
      <!-- Backdrop -->
      <div id="mobile-toc-backdrop" class="mobile-toc-backdrop" aria-hidden="true"></div>
      <!-- Drawer from right -->
      <div id="mobile-toc-drawer" class="mobile-toc-drawer" role="dialog" aria-modal="true" aria-label="Table of contents">
        <div class="mobile-toc-drawer-header">
          <span class="mobile-toc-drawer-title">Contents</span>
          <button id="mobile-toc-close" class="mobile-toc-close-btn" aria-label="Close table of contents">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>
        <nav>
          <ul class="mobile-toc-list">
            {headings.filter(h => h.depth === 2 || h.depth === 3).map(h => (
              <li>
                <a
                  href={`#${h.slug}`}
                  class={`mobile-toc-link${h.depth === 3 ? ' mobile-toc-link--sub' : ''}`}
                >
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </div>
  )}

  <!-- ── Full-width footer — outside the grid so border-top spans all of <main> -->
  <footer class="article-footer">
    <div class="article-footer-inner">
      <a href="/#newsletter" class="footer-link">Newsletter →</a>
      <a href="/about" class="footer-link">About →</a>
      <a href="/contact" class="footer-link">Contact →</a>
      <a href="/privacy" class="footer-link">Privacy →</a>
      <a
        href="https://etsy.com"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-link"
      >Travel templates →</a>
    </div>
    <p class="footer-copy">{new Date().getFullYear()} GoinAtlas. All rights reserved.</p>
  </footer>

</BaseLayout>

<style>
  /*
    ── 3-col grid: [TOC 1fr] [content min(680px,100%)] [right 1fr] ───────
    Grid is ALWAYS active. The center column naturally handles every width:
    · < 680px  → center = 100vw (full bleed), 1fr side cols = 0
    · 680–1440px → center = 680px fixed, side cols grow symmetrically
    · ≥ 1440px → same grid + TOC floats inside the left 1fr column
  */
  .article-grid {
    display: grid;
    grid-template-columns: 1fr min(680px, 100%) 1fr;
  }

  /* ── TOC column — hidden until ≥1440px ─────────────────────── */
  .toc-column { display: none; }

  /* ── Article content — fluid padding, no inline style ────────
     Matches content left edge at every breakpoint.
     On < 480px: 1.25rem (20px)
     On 480px+: 1.5rem (24px)
     On 1440px+: 100px (to create breathing room next to TOC)
  */
  .article-content-col {
    grid-column: 2; /* Always column 2 — regardless of whether toc-column is in the flow */
    padding: 2rem 1.25rem 4rem;
  }
  @media (min-width: 480px) {
    .article-content-col {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
  }

  /* ── Breadcrumb — always tracks the center column's left edge ──
     Formula: max(base, (screen_width − 680px) / 2 + base)
     · < 680px → max kicks in, padding = base (24px) since calc is ≤ 0
     · 680–1440px → calc grows smoothly, always = center_col_left + base
     · ≥ 1440px → overridden to 140px to align with the TOC sidebar
  */
  .breadcrumb-indent {
    padding-left: max(1.25rem, calc((100% - 680px) / 2 + 1.25rem));
    padding-right: 1.5rem;
  }
  @media (min-width: 480px) {
    .breadcrumb-indent {
      padding-left: max(1.5rem, calc((100% - 680px) / 2 + 1.5rem));
    }
  }

  /* ── Hero meta pill — mirrors breadcrumb formula from the right ──
     Same logic, mirrored: right = max(base, (100% − 680px) / 2 + base)
     so the pill tracks the center column's right edge at all widths.
  */
  .meta-pill-anchor {
    top: 16px;
    right: max(1.25rem, calc((100% - 680px) / 2 + 1.25rem));
  }
  @media (min-width: 480px) {
    .meta-pill-anchor {
      right: max(1.5rem, calc((100% - 680px) / 2 + 1.5rem));
    }
  }

  /* ── Article inline ad — mobile/tablet only ─────────────────── */
  /* On ≥1280px the col3 ad rail handles impressions instead. */
  .article-inline-ad { display: flex; }
  @media (min-width: 1280px) {
    .article-inline-ad { display: none; }
  }

  /* ── Article col3 ad rail ────────────────────────────────────── */
  /* Hidden until the 1fr column is wide enough to show a real ad. */
  /* At 1280px: 1fr = (1280−680)/2 = 300px — fits a 250px ad. */
  .article-col3-ads {
    display: none;
    padding: 2.5rem 1rem 4rem 2.5rem;
    /* no max-width — fills 1fr naturally (matches header search bar proportions) */
  }
  @media (min-width: 1280px) {
    .article-col3-ads { display: block; }
  }

  /* Sticky BookingCTA in col3 — follows scroll, stops before footer */
  .col3-booking-sticky {
    position: sticky;
    top: calc(4rem + 2.75rem + 1rem); /* header + breadcrumb + gap */
    z-index: 10;
    margin-bottom: 1.5rem;
  }

  /* Inline BookingCTAs — shown on mobile, hidden when col3 is visible */
  .article-booking-inline { display: block; }
  @media (min-width: 1280px) {
    .article-booking-inline { display: none; }
  }

  /* ── 1440px: TOC sidebar + article offset ───────────────────── */
  /* Cap col1 at 380px so on wide screens (1920px+) the article stays
     close to the TOC instead of floating to the center of the viewport */
  @media (min-width: 1440px) {
    .article-grid {
      grid-template-columns: minmax(0, 380px) min(680px, 100%) 1fr;
    }
    .toc-column {
      display: flex;
      padding-left: 140px;
      padding-right: 1.5rem;
    }
    .article-content-col {
      padding-left: 2.5rem;
      padding-right: 1.5rem;
    }
    .breadcrumb-indent {
      padding-left: 140px;
    }
    .meta-pill-anchor {
      right: max(1.5rem, calc((100% - 680px) / 2 + 1.5rem));
    }
  }

  /* ── Full-width article footer — lives outside the grid ─── */
  .article-footer {
    border-top: 1px solid var(--color-border);
    padding: 1.25rem 2rem;
    margin-top: 4rem;
  }
  .article-footer-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.25rem;
  }
  .footer-link {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 700;
    color: var(--color-text-primary);
    text-decoration: none;
    transition: opacity 0.12s;
  }
  .footer-link:hover {
    opacity: 0.6;
  }
  .footer-copy {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* ── Mobile TOC FAB ──────────────────────────────────────── */
  /* Only visible when sidebar TOC is hidden (< 1440px) */
  #mobile-toc-root {
    display: block;
  }
  @media (min-width: 1440px) {
    #mobile-toc-root { display: none; }
  }

  .mobile-toc-fab {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: var(--color-text-primary);
    color: #fff;
    border: none;
    border-radius: 9999px;
    padding: 0.6rem 1.2rem;
    font-size: 0.8125rem;
    font-weight: 600;
    font-family: var(--font-body);
    cursor: pointer;
    z-index: 90;
    box-shadow: 0 4px 16px rgba(0,0,0,0.18);
    white-space: nowrap;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .mobile-toc-fab:hover {
    transform: translateX(-50%) scale(1.04);
    box-shadow: 0 6px 20px rgba(0,0,0,0.22);
  }

  /* ── Mobile TOC Backdrop ─────────────────────────────────── */
  .mobile-toc-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.42);
    z-index: 200;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease;
  }
  .mobile-toc-backdrop.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Mobile TOC Drawer (slides in from right) ────────────── */
  .mobile-toc-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(320px, 85vw);
    background: var(--color-surface);
    z-index: 201;
    transform: translateX(100%);
    transition: transform 0.25s ease;
    overflow-y: auto;
    padding: 0 0 2rem 0;
    box-shadow: -4px 0 24px rgba(0,0,0,0.1);
  }
  .mobile-toc-drawer.is-open {
    transform: translateX(0);
  }
  .mobile-toc-drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.25rem 1rem;
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    background: var(--color-surface);
    z-index: 1;
  }
  .mobile-toc-drawer-title {
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--color-text-primary);
    font-family: var(--font-body);
  }
  .mobile-toc-close-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    color: var(--color-text-secondary);
    border-radius: 6px;
    transition: background 0.12s, color 0.12s;
  }
  .mobile-toc-close-btn:hover {
    background: var(--color-bg-subtle);
    color: var(--color-text-primary);
  }
  .mobile-toc-list {
    list-style: none;
    margin: 0.75rem 0 0;
    padding: 0 0.75rem;
  }
  .mobile-toc-link {
    display: block;
    padding: 0.55rem 0.75rem;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: 0.375rem;
    transition: background 0.12s, color 0.12s;
    line-height: 1.4;
  }
  .mobile-toc-link:hover,
  .mobile-toc-link:active {
    background: var(--color-bg-subtle);
    color: var(--color-text-primary);
  }
  .mobile-toc-link--sub {
    padding-left: 1.5rem;
    font-size: 0.775rem;
    color: var(--color-text-muted);
  }

  /* ── Action icon buttons (Save + Share) ─────────────────── */
  .action-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: black;
    transition: transform 0.12s ease;
  }
  .action-icon-btn:hover {
    transform: scale(1.09);
  }
  .save-btn.is-saved {
    color: black;
  }
</style>

<script>
  // ── Share button ──────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('[data-share-btn]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url  = new URL(btn.dataset.shareBtn!, window.location.origin).href;
      const text = btn.dataset.shareTitle || document.title;
      if (navigator.share) {
        try { await navigator.share({ title: text, url }); } catch { /* user cancelled */ }
      } else {
        try {
          await navigator.clipboard.writeText(url);
          // Brief visual feedback
          const orig = btn.innerHTML;
          btn.innerHTML = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>';
          setTimeout(() => { btn.innerHTML = orig; }, 1500);
        } catch { /* clipboard denied */ }
      }
    });
  });
</script>

<script>
  // ── Mobile TOC drawer ─────────────────────────────────────
  const fab      = document.getElementById('mobile-toc-fab');
  const backdrop = document.getElementById('mobile-toc-backdrop');
  const drawer   = document.getElementById('mobile-toc-drawer');
  const closeBtn = document.getElementById('mobile-toc-close');

  function openMobileToc() {
    backdrop?.classList.add('is-open');
    drawer?.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }
  function closeMobileToc() {
    backdrop?.classList.remove('is-open');
    drawer?.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  fab?.addEventListener('click', openMobileToc);
  backdrop?.addEventListener('click', closeMobileToc);
  closeBtn?.addEventListener('click', closeMobileToc);

  // Close when a heading link is tapped
  drawer?.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMobileToc));
</script>

<script>
  // Set --toc-contents-top so CSS scroll-margin-top matches the
  // actual sticky position of "Contents" (used for hash-navigation)
  function syncScrollMargin() {
    const tocTitle = document.querySelector<HTMLElement>('.toc-title');
    if (tocTitle) {
      const top = tocTitle.getBoundingClientRect().top;
      document.documentElement.style.setProperty('--toc-contents-top', `${top}px`);
    }
  }
  syncScrollMargin();
  window.addEventListener('resize', syncScrollMargin);
</script>
