---
import '../styles/global.css';
import Header from '../components/Header.astro';
import GlobalSidebar from '../components/GlobalSidebar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  hideFooter?: boolean;
  schema?: Record<string, unknown>;
}

const { title, description, image = '/og-default.jpg', hideFooter = false, schema } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Google Fonts — preconnect first, then non-blocking stylesheet -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Unbounded:wght@700;900&family=Inter:wght@400;500;600&display=swap" />

    <!-- SEO -->
    <title>{title} | GoinAtlas</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="uSCCwZzt0E21t7jko_0NExb081WaWE1FtF2cqsfmjBI" />

    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1981760864692469" crossorigin="anonymous"></script>

    <!-- Travelpayouts Drive — deferred until after page load to avoid LCP/TBT impact -->
    <script is:inline>
      window.addEventListener('load', function () {
        var script = document.createElement("script");
        script.async = true;
        script.src = 'https://emrld.ltd/NTMwODYx.js?t=530861';
        document.head.appendChild(script);
      });
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | GoinAtlas`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | GoinAtlas`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Structured data (JSON-LD) -->
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

    <!--
      Prevent layout shift and header flash on every page navigation.
      Runs synchronously in <head> — before a single pixel of <body> is painted.
    -->
    <script is:inline>
      (function() {
        try {
          var sc = localStorage.getItem('goinatlas:sidebar-collapsed') === '1' || window.innerWidth < 1280;
          var css = '';

          // Always kill toggle-button transitions during initial paint
          css += '#sidebar-toggle-btn,#sidebar-collapse-btn{transition:none!important}';

          if (sc) {
            // Sidebar collapsed: hide it immediately, no slide animation
            css += '#global-sidebar{width:0!important;transition:none!important}';
            // Header: hamburger visible (default), collapse hidden (default) — no extra CSS needed
          } else {
            // Sidebar open: show collapse button, hide hamburger — before JS runs
            css += '#sidebar-toggle-btn{max-width:0!important;opacity:0!important;padding-left:0!important;padding-right:0!important;pointer-events:none!important}';
            css += '#sidebar-collapse-btn{max-width:40px!important;opacity:1!important;padding-left:0.5rem!important;padding-right:0.5rem!important;pointer-events:auto!important}';
          }

          var el = document.createElement('style');
          el.id = 'goinatlas-init-css';
          el.textContent = css;
          document.head.appendChild(el);
        } catch(e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-[var(--color-bg)]">
    <Header />
    <div class="flex flex-1 min-h-0">
      <GlobalSidebar />
      <main class="flex-1 min-w-0 overflow-x-clip">
        <slot />
      </main>
    </div>
    {!hideFooter && <Footer />}
  </body>
</html>

<script>
  // ── Reading-list save buttons (site-wide) ──────────────────────────────
  const RL_KEY = 'goinatlas:reading-list';

  function rlGet(): string[] {
    try { return JSON.parse(localStorage.getItem(RL_KEY) || '[]'); } catch { return []; }
  }
  function rlSet(list: string[]) { localStorage.setItem(RL_KEY, JSON.stringify(list)); }

  function setSaved(btn: HTMLElement, isSaved: boolean) {
    const outline = btn.querySelector<SVGElement>('.save-icon-outline');
    const filled  = btn.querySelector<SVGElement>('.save-icon-filled');
    const label   = btn.querySelector<HTMLElement>('.save-btn-label');
    outline?.classList.toggle('hidden', isSaved);
    filled?.classList.toggle('hidden', !isSaved);
    if (label) {
      const unsavedText = btn.dataset.saveLabel || 'Save';
      label.textContent = isSaved ? 'Saved' : unsavedText;
    }
    btn.setAttribute('aria-pressed', isSaved ? 'true' : 'false');
    btn.classList.toggle('is-saved', isSaved);
  }

  function initSaveBtns() {
    const saved = new Set(rlGet());
    document.querySelectorAll<HTMLElement>('[data-save-btn]').forEach((btn) => {
      if (btn.dataset.saveInit) return; // already wired
      btn.dataset.saveInit = '1';
      const url = btn.dataset.saveBtn!;
      setSaved(btn, saved.has(url));
      btn.addEventListener('click', (e) => {
        e.stopPropagation(); // prevent anchor navigation when inside <a>
        const list = rlGet();
        const idx  = list.indexOf(url);
        if (idx >= 0) { list.splice(idx, 1); } else { list.push(url); }
        rlSet(list);
        const wasSaved = idx < 0; // true = just saved, false = just removed
        setSaved(btn, wasSaved);
        document.dispatchEvent(new CustomEvent('goinatlas:readingListChanged', { detail: { saved: wasSaved } }));
      });
    });
  }

  initSaveBtns();

  // ── Footer placement ──────────────────────────────────────────────────────
  // >=xl : position:fixed bottom-right — handled entirely by CSS / Tailwind classes.
  // <xl  : move into #articles-scroll as a full-width static block at the bottom.
  (function initFooter() {
    const footer = document.getElementById('site-footer');
    if (!footer) return;

    const originalParent    = footer.parentElement!;
    const originalSibling   = footer.nextSibling;

    function placeFooter() {
      const scroll = document.getElementById('articles-scroll');
      const isXL   = window.innerWidth >= 1280;

      if (isXL) {
        // ── xl+: restore to original DOM position; CSS takes over ──────────
        if (footer.parentElement !== originalParent) {
          originalSibling
            ? originalParent.insertBefore(footer, originalSibling)
            : originalParent.appendChild(footer);
        }
        // Clear any inline overrides set by the <xl branch
        footer.style.cssText = 'width: 354px; padding: 1rem 1.5rem 1.25rem 30px;';

      } else if (scroll) {
        // ── <xl: full-width static block at bottom of articles scroll ───────
        if (footer.parentElement !== scroll) scroll.appendChild(footer);
        footer.style.cssText =
          'position:static; width:100%; display:block; padding:1.5rem 1.5rem 2.5rem;';

      } else {
        // no hub page — keep hidden
        footer.style.display = 'none';
      }
    }

    placeFooter();
    window.addEventListener('resize', () => placeFooter());
  })();

</script>
