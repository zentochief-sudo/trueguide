---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import GlobalSidebar from '../components/GlobalSidebar.astro';
import Footer from '../components/Footer.astro';
import AuthModal from '../components/AuthModal.astro';
import PageSkeleton from '../components/PageSkeleton.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  hideFooter?: boolean;
  schema?: Record<string, unknown>;
}

const { title, description, image = '/og-default.jpg', hideFooter = false, schema } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <!-- DNS prefetch for third-party origins (non-blocking, speculative) -->
    <link rel="dns-prefetch" href="https://pagead2.googlesyndication.com" />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <!-- Preconnect for Travelpayouts Drive — saves ~320ms LCP (Lighthouse candidate) -->
    <link rel="preconnect" href="https://emrld.ltd" />

    <!-- Google Fonts — async (non-render-blocking) load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Unbounded:wght@700;900&family=Inter:wght@400;500;600&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Unbounded:wght@700;900&family=Inter:wght@400;500;600&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Unbounded:wght@700;900&family=Inter:wght@400;500;600&display=swap" /></noscript>

    <!-- SEO -->
    <title>{title} | GoinAtlas</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="uSCCwZzt0E21t7jko_0NExb081WaWE1FtF2cqsfmjBI" />

    <!-- Google AdSense — async avoids render-blocking; fires after HTML parse -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1981760864692469" crossorigin="anonymous"></script>

    <!-- Travelpayouts Drive — deferred until after page load to avoid LCP/TBT impact -->
    <script is:inline>
      window.addEventListener('load', function () {
        var script = document.createElement("script");
        script.async = true;
        script.src = 'https://emrld.ltd/NTMwODYx.js?t=530861';
        document.head.appendChild(script);
      });
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | GoinAtlas`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | GoinAtlas`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Structured data (JSON-LD) -->
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HR3B24XK6G"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-HR3B24XK6G');
    </script>

    <!-- ClientRouter — SPA-like navigation without full page reloads (Astro 6) -->
    <ClientRouter />

    <!--
      Prevent layout shift and header flash on every page navigation.
      Runs synchronously in <head> — before a single pixel of <body> is painted.
    -->
    <script is:inline>
      (function() {
        try {
          var sc = localStorage.getItem('goinatlas:sidebar-collapsed') === '1' || window.innerWidth < 1280;
          var css = '';

          // Always kill toggle-button transitions during initial paint
          css += '#sidebar-toggle-btn,#sidebar-collapse-btn{transition:none!important}';

          if (sc) {
            // Sidebar collapsed: hide it immediately, no slide animation
            css += '#global-sidebar{width:0!important;transition:none!important}';
            // Header: hamburger visible (default), collapse hidden (default) — no extra CSS needed
          } else {
            // Sidebar open: show collapse button, hide hamburger — before JS runs
            css += '#sidebar-toggle-btn{max-width:0!important;opacity:0!important;padding-left:0!important;padding-right:0!important;pointer-events:none!important}';
            css += '#sidebar-collapse-btn{max-width:40px!important;opacity:1!important;padding-left:0.5rem!important;padding-right:0.5rem!important;pointer-events:auto!important}';
          }

          var el = document.createElement('style');
          el.id = 'goinatlas-init-css';
          el.textContent = css;
          document.head.appendChild(el);
        } catch(e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-[var(--color-bg)]">
    <!-- Navigation progress bar -->
    <div id="nav-progress" aria-hidden="true"></div>
    <Header />
    <div class="flex flex-1 min-h-0">
      <GlobalSidebar />
      <main class="flex-1 min-w-0 overflow-x-clip" style="position: relative;">
        <PageSkeleton />
        <slot />
      </main>
    </div>
    {!hideFooter && <Footer />}
    <AuthModal />
  </body>
</html>

<script>
  // ── Reading-list save buttons (site-wide) ──────────────────────────────
  const RL_KEY = 'goinatlas:reading-list';

  function rlGet(): string[] {
    try { return JSON.parse(localStorage.getItem(RL_KEY) || '[]'); } catch { return []; }
  }
  function rlSet(list: string[]) { localStorage.setItem(RL_KEY, JSON.stringify(list)); }

  function setSaved(btn: HTMLElement, isSaved: boolean) {
    const outline = btn.querySelector<SVGElement>('.save-icon-outline');
    const filled  = btn.querySelector<SVGElement>('.save-icon-filled');
    const label   = btn.querySelector<HTMLElement>('.save-btn-label');
    outline?.classList.toggle('hidden', isSaved);
    filled?.classList.toggle('hidden', !isSaved);
    if (label) {
      const unsavedText = btn.dataset.saveLabel || 'Save';
      label.textContent = isSaved ? 'Saved' : unsavedText;
    }
    btn.setAttribute('aria-pressed', isSaved ? 'true' : 'false');
    btn.classList.toggle('is-saved', isSaved);
  }

  function initSaveBtns() {
    const saved = new Set(rlGet());
    document.querySelectorAll<HTMLElement>('[data-save-btn]').forEach((btn) => {
      if (btn.dataset.saveInit) return; // already wired
      btn.dataset.saveInit = '1';
      const url = btn.dataset.saveBtn!;
      setSaved(btn, saved.has(url));
      btn.addEventListener('click', (e) => {
        e.stopPropagation(); // prevent anchor navigation when inside <a>
        const list = rlGet();
        const idx  = list.indexOf(url);
        if (idx >= 0) { list.splice(idx, 1); } else { list.push(url); }
        rlSet(list);
        const wasSaved = idx < 0; // true = just saved, false = just removed
        setSaved(btn, wasSaved);
        document.dispatchEvent(new CustomEvent('goinatlas:readingListChanged', { detail: { saved: wasSaved } }));
      });
    });
  }

  initSaveBtns();
  // Re-init on ViewTransitions navigation (new page content may have save buttons)
  document.addEventListener('astro:page-load', initSaveBtns);

  // ── Footer placement ──────────────────────────────────────────────────────
  // >=xl : position:fixed bottom-right — handled entirely by CSS / Tailwind classes.
  // <xl  : move into #articles-scroll as a full-width static block at the bottom.
  (function initFooter() {
    const footer = document.getElementById('site-footer');
    if (!footer) return;

    const originalParent    = footer.parentElement!;
    const originalSibling   = footer.nextSibling;

    function placeFooter() {
      const scroll = document.getElementById('articles-scroll');
      const isXL   = window.innerWidth >= 1280;

      if (isXL) {
        // ── xl+: restore to original DOM position; CSS takes over ──────────
        if (footer.parentElement !== originalParent) {
          originalSibling
            ? originalParent.insertBefore(footer, originalSibling)
            : originalParent.appendChild(footer);
        }
        // Clear any inline overrides set by the <xl branch
        footer.style.cssText = 'width: 354px; padding: 1rem 1.5rem 1.25rem 30px;';

      } else if (scroll) {
        // ── <xl: full-width static block at bottom of articles scroll ───────
        if (footer.parentElement !== scroll) scroll.appendChild(footer);
        footer.style.cssText =
          'position:static; width:100%; display:block; padding:1.5rem 1.5rem 2.5rem;';

      } else {
        // no hub page — keep hidden
        footer.style.display = 'none';
      }
    }

    placeFooter();
    window.addEventListener('resize', () => placeFooter());
  })();

  // ── Navigation progress bar + skeleton ───────────────────────────────────
  (function initNavProgress() {
    const bar = document.getElementById('nav-progress');
    let timer: ReturnType<typeof setTimeout>;

    function getSkeleton() {
      return document.getElementById('page-skeleton') as HTMLElement | null;
    }

    function start() {
      // Progress bar
      if (bar) {
        clearTimeout(timer);
        bar.style.transition = 'none';
        bar.style.width = '0%';
        bar.style.opacity = '1';
        bar.getBoundingClientRect();
        bar.style.transition = 'width 2.5s cubic-bezier(0.1, 0.05, 0, 1)';
        bar.style.width = '85%';
      }
      // Skeleton: fade out current content, show skeleton
      const sk = getSkeleton();
      if (sk) {
        sk.style.display = 'block';
        sk.style.opacity = '0';
        sk.style.transition = 'opacity 0.15s ease';
        requestAnimationFrame(() => { sk.style.opacity = '1'; });
      }
    }

    function done() {
      // Progress bar
      if (bar) {
        clearTimeout(timer);
        bar.style.transition = 'width 0.15s ease';
        bar.style.width = '100%';
        timer = setTimeout(() => {
          bar.style.transition = 'opacity 0.3s ease';
          bar.style.opacity = '0';
          timer = setTimeout(() => { bar.style.width = '0%'; }, 350);
        }, 150);
      }
      // Skeleton: hide (new page content is already in DOM after swap)
      const sk = getSkeleton();
      if (sk) {
        sk.style.transition = 'opacity 0.2s ease';
        sk.style.opacity = '0';
        setTimeout(() => { sk.style.display = 'none'; }, 220);
      }
    }

    document.addEventListener('astro:before-preparation', start);
    document.addEventListener('astro:page-load', done);
  })();

</script>

<style>
  #nav-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    width: 0%;
    background: var(--color-brand-600, #5269DB);
    z-index: 99999;
    opacity: 0;
    pointer-events: none;
    border-radius: 0 2px 2px 0;
    box-shadow: 0 0 8px 0 color-mix(in srgb, var(--color-brand-600, #5269DB) 60%, transparent);
  }
</style>
