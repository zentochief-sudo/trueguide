---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact GoinAtlas"
  description="Get in touch with the GoinAtlas team for corrections, partnerships, or general inquiries."
>
  <div class="max-w-2xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-bold mb-6" style="font-family: var(--font-display);">Contact Us</h1>

    <p class="text-[var(--color-text-secondary)] mb-8 leading-relaxed">
      We read every message. Whether you've spotted an error, want to suggest a destination, or are interested in working together — reach out.
    </p>

    <div class="space-y-6">
      <div class="p-6 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)]">
        <h2 class="font-bold text-[var(--color-text-primary)] mb-1" style="font-family: var(--font-display);">General inquiries</h2>
        <p class="text-sm text-[var(--color-text-secondary)] mb-3">Questions about the site, content corrections, destination suggestions.</p>
        <a href="mailto:hello@goinatlas.com" class="text-[var(--color-brand-600)] font-semibold hover:underline">
          hello@goinatlas.com
        </a>
      </div>

      <div class="p-6 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)]">
        <h2 class="font-bold text-[var(--color-text-primary)] mb-1" style="font-family: var(--font-display);">Partnerships & advertising</h2>
        <p class="text-sm text-[var(--color-text-secondary)] mb-3">Sponsorships, content partnerships, affiliate programs.</p>
        <a href="mailto:partnerships@goinatlas.com" class="text-[var(--color-brand-600)] font-semibold hover:underline">
          partnerships@goinatlas.com
        </a>
      </div>
    </div>

    <p class="text-sm text-[var(--color-text-muted)] mt-10">
      We typically respond within 2–3 business days.
    </p>
  </div>
</BaseLayout>
