---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCarousel from '../components/ArticleCarousel.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import WorldMap from '../components/WorldMap.astro';
import { getCollection } from 'astro:content';

const japanArticles = await getCollection('japan');

let koreaArticles: typeof japanArticles = [];
try { koreaArticles = await getCollection('korea'); } catch {}

const allArticles = [...japanArticles, ...koreaArticles]
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const carouselArticles = allArticles.map((a) => ({
  title: a.data.title,
  description: a.data.description,
  destination: a.data.destination,
  category: a.data.category,
  slug: a.id,
  heroImage: a.data.heroImage,
  readingTime: a.data.readingTime,
  city: a.data.city,
}));

const destinations = [
  { label: 'Japan', href: '/japan' },
  { label: 'South Korea', href: '/korea' },
];
---

<BaseLayout
  title="Deep Travel Guides for the Curious Traveler"
  description="GoinAtlas — deep, honest travel guides for Japan, South Korea and beyond. Itineraries, food guides, and travel planning templates."
>
  <!-- Hero: headline + world map -->
  <section class="bg-white border-b border-[var(--color-border)] py-6 md:py-8 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h1
        class="text-[40px] leading-tight font-black text-[var(--color-text-primary)] mb-6"
        style="font-family: var(--font-display); font-weight: 900;"
      >
        Travel like someone<br/>who actually knows.
      </h1>
      <WorldMap />
    </div>
  </section>

  <!-- Destination tabs + Popular guides carousel -->
  <section class="max-w-6xl mx-auto px-6 pt-10 pb-8">

    <!-- Destination tabs — navigate to country page -->
    <div class="border-b border-[var(--color-border)] mb-10">
      <div class="flex gap-0 -mb-px">
        {destinations.map((dest) => (
          <a
            href={dest.href}
            class="px-5 py-3 text-sm border-b-2 border-b-transparent whitespace-nowrap transition-colors font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:border-b-[var(--color-brand-600)]"
          >
            {dest.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Popular guides -->
    <div class="mb-6 flex items-baseline justify-between">
      <h2
        class="text-xl font-black text-[var(--color-text-primary)]"
        style="font-family: var(--font-display); font-weight: 900;"
      >
        Popular guides
      </h2>
      <span class="text-xs text-[var(--color-text-muted)]">{allArticles.length} guides</span>
    </div>

    <ArticleCarousel articles={carouselArticles} id="popular" />

  </section>

  <!-- Newsletter -->
  <section class="max-w-4xl mx-auto px-6 pb-20">
    <NewsletterSignup />
  </section>
</BaseLayout>
