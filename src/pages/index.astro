---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import WorldMap from '../components/WorldMap.astro';
import { getCollection } from 'astro:content';

const japanArticles = await getCollection('japan');

let koreaArticles: typeof japanArticles = [];
try { koreaArticles = await getCollection('korea'); } catch {}

const allArticles = [...japanArticles, ...koreaArticles]
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const destinations = [
  { label: 'Japan', href: '/japan' },
  { label: 'South Korea', href: '/korea' },
];
---

<BaseLayout
  title="Deep Travel Guides for the Curious Traveler"
  description="GoinAtlas — deep, honest travel guides for Japan, South Korea and beyond. Itineraries, food guides, and travel planning templates."
>
  <!-- Hero: headline + world map -->
  <section class="bg-white border-b border-[var(--color-border)] py-6 md:py-8 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h1
        class="text-[40px] leading-tight font-black text-[var(--color-text-primary)] mb-6"
        style="font-family: var(--font-display); font-weight: 900;"
      >
        Travel like someone<br/>who actually knows.
      </h1>
      <WorldMap />
    </div>
  </section>

  <!-- Tabs + article grid -->
  <section class="max-w-6xl mx-auto px-6 pt-10 pb-8">
    <!-- Destination tabs — navigate to country page -->
    <div class="border-b border-[var(--color-border)] mb-8">
      <div class="flex gap-0 -mb-px">
        {destinations.map((dest) => (
          <a
            href={dest.href}
            class="px-5 py-3 text-sm border-b-2 whitespace-nowrap transition-colors font-medium text-[var(--color-text-secondary)] border-b-transparent hover:text-[var(--color-text-primary)] hover:border-b-[var(--color-brand-600)]"
          >
            {dest.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden text-center py-16">
      <p class="text-[var(--color-text-muted)] text-sm">No guides found.</p>
    </div>

    <!-- Articles grid -->
    <div id="articles-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {allArticles.map((article) => (
        <ArticleCard
          title={article.data.title}
          description={article.data.description}
          destination={article.data.destination}
          category={article.data.category}
          slug={article.id}
          heroImage={article.data.heroImage}
          readingTime={article.data.readingTime}
          city={article.data.city}
        />
      ))}
    </div>
  </section>

  <!-- Newsletter -->
  <section class="max-w-4xl mx-auto px-6 pb-20">
    <NewsletterSignup />
  </section>
</BaseLayout>

