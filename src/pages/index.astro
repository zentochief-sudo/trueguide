---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import WorldMap from '../components/WorldMap.astro';
import { getCollection } from 'astro:content';

const japanArticles = await getCollection('japan');

let koreaArticles: typeof japanArticles = [];
try { koreaArticles = await getCollection('korea'); } catch {}

const allArticles = [...japanArticles, ...koreaArticles]
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const tabs = [
  { id: 'all', label: 'All Guides' },
  { id: 'japan', label: 'Japan' },
  { id: 'korea', label: 'South Korea' },
];
---

<BaseLayout
  title="Deep Travel Guides for the Curious Traveler"
  description="GoinAtlas — deep, honest travel guides for Japan, South Korea and beyond. Itineraries, food guides, and travel planning templates."
>
  <!-- Hero: headline + world map -->
  <section class="bg-white border-b border-[var(--color-border)] py-12 md:py-16 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h1
        class="text-[40px] leading-tight font-black text-[var(--color-text-primary)] mb-4"
        style="font-family: var(--font-display); font-weight: 900;"
      >
        Go deeper.<br/>Travel better.
      </h1>
      <p class="text-base text-[var(--color-text-secondary)] max-w-md mx-auto mb-10">
        Honest guides for people who want to actually experience a place.
      </p>
      <WorldMap />
    </div>
  </section>

  <!-- Tabs + article grid -->
  <section class="max-w-6xl mx-auto px-6 pt-10 pb-8">
    <!-- Tab bar -->
    <div class="border-b border-[var(--color-border)] mb-8">
      <div class="flex gap-0 -mb-px" id="home-tabs">
        {tabs.map((tab, i) => (
          <button
            class="tab-btn px-5 py-3 text-sm border-b-2 whitespace-nowrap transition-colors"
            data-tab={tab.id}
            style={i === 0
              ? 'color: var(--color-brand-600); border-bottom-color: var(--color-brand-600); font-weight: 600;'
              : 'color: var(--color-text-muted); border-bottom-color: transparent; font-weight: 500;'}
          >
            {tab.label}
          </button>
        ))}
      </div>
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden text-center py-16">
      <p class="text-[var(--color-text-muted)] text-sm">No guides found.</p>
    </div>

    <!-- Articles grid -->
    <div id="articles-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {allArticles.map((article) => (
        <ArticleCard
          title={article.data.title}
          description={article.data.description}
          destination={article.data.destination}
          category={article.data.category}
          slug={article.id}
          heroImage={article.data.heroImage}
          readingTime={article.data.readingTime}
          city={article.data.city}
        />
      ))}
    </div>
  </section>

  <!-- Newsletter -->
  <section class="max-w-4xl mx-auto px-6 pb-20">
    <NewsletterSignup />
  </section>
</BaseLayout>

<script>
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const cards = document.querySelectorAll<HTMLElement>('[data-article-card]');
  const emptyState = document.getElementById('empty-state');

  let activeTab = 'all';

  const activeTabStyle = {
    color: 'var(--color-brand-600)',
    borderBottomColor: 'var(--color-brand-600)',
    fontWeight: '600',
  };
  const inactiveTabStyle = {
    color: 'var(--color-text-muted)',
    borderBottomColor: 'transparent',
    fontWeight: '500',
  };

  function applyTabStyles() {
    tabBtns.forEach((btn) => {
      const s = btn.dataset.tab === activeTab ? activeTabStyle : inactiveTabStyle;
      btn.style.color = s.color;
      btn.style.borderBottomColor = s.borderBottomColor;
      btn.style.fontWeight = s.fontWeight;
    });
  }

  function applyFilters() {
    let visible = 0;
    cards.forEach((card) => {
      const matchesTab = activeTab === 'all' || card.dataset.destination === activeTab;
      const show = matchesTab;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (emptyState) emptyState.style.display = visible === 0 ? '' : 'none';
  }

  function setActiveTab(tab: string) {
    activeTab = tab;
    applyTabStyles();
    applyFilters();
  }

  applyFilters();

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => setActiveTab(btn.dataset.tab!));
  });

  // Search from header
  document.addEventListener('trueguide:search', ((e: CustomEvent) => {
    const q = (e.detail.query ?? '').toLowerCase();
    cards.forEach((card) => {
      const match = !q ||
        (card.dataset.title ?? '').includes(q) ||
        (card.dataset.description ?? '').includes(q);
      card.style.display = match ? '' : 'none';
    });
  }) as EventListener);
</script>
