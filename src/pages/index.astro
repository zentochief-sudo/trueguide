---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import HubBanner from '../components/HubBanner.astro';
import TrendingNow from '../components/TrendingNow.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { getCollection } from 'astro:content';

const japanArticles  = await getCollection('japan');
let koreaArticles: typeof japanArticles = [];
try { koreaArticles = await getCollection('korea'); } catch {}

const allArticles = [...japanArticles, ...koreaArticles]
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const categories = [
  { id: 'itinerary', label: 'Itinerary' },
  { id: 'culture',   label: 'Culture' },
  { id: 'food',      label: 'Food & Drink' },
  { id: 'tips',      label: 'Tips' },
  { id: 'transport', label: 'Transport' },
  { id: 'budget',    label: 'Budget' },
];

const activityTypes = [
  { id: 'food-drink',   label: '🍜 Food & Drink' },
  { id: 'temples',      label: '⛩️ Temples' },
  { id: 'nature',       label: '🌿 Nature & Rural' },
  { id: 'shopping',     label: '🛍️ Shopping' },
  { id: 'history',      label: '📜 History' },
  { id: 'museums',      label: '🏛️ Museums' },
  { id: 'onsen',        label: '♨️ Onsen' },
  { id: 'festivals',    label: '🎋 Festivals' },
  { id: 'castles',      label: '🏯 Castles' },
  { id: 'architecture', label: '🏗️ Architecture' },
];
---

<BaseLayout
  title="Deep Travel Guides for the Curious Traveler"
  description="GoinAtlas — deep, honest travel guides for Japan, South Korea and beyond."
>

  <div id="home-shell" class="flex flex-col" style="height: calc(100vh - 4rem); overflow: hidden;">

    <!-- Banner -->
    <HubBanner />

    <!-- Content row -->
    <div class="flex flex-1 min-h-0">

      <!-- Feed column -->
      <div class="flex-1 min-w-0 flex flex-col overflow-hidden">
        <div class="flex flex-col flex-1 min-h-0" style="padding-left: 160px; padding-right: 76px;">

          <!-- Tabs row — tabs + filter icon on the right -->
          <nav class="flex items-center border-b border-[var(--color-border)] bg-[var(--color-bg)] shrink-0" style="padding-top: 2.5rem;">

            <!-- Tab buttons -->
            <div class="flex overflow-x-auto scrollbar-hide flex-1">
              <button class="hub-tab is-active" data-tab="for-you">For you</button>
              <button class="hub-tab" data-tab="popular">Popular this week</button>
              <button class="hub-tab" data-tab="all">All guides</button>
              <button class="hub-tab" data-tab="explore">Explore Map</button>
            </div>

            <!-- Filter icon — right side, aligned with tabs bottom border -->
            <div class="shrink-0 flex items-end self-stretch" style="margin-bottom: -1px;">
              <button
                id="filter-btn"
                class="filter-icon-btn flex items-center gap-1.5 px-4 pb-[0.65rem] text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors border-b-2 border-transparent"
                aria-label="Open filters"
                type="button"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="4" y1="6" x2="20" y2="6"/>
                  <circle cx="8" cy="6" r="2" fill="currentColor" stroke="none"/>
                  <line x1="4" y1="12" x2="20" y2="12"/>
                  <circle cx="16" cy="12" r="2" fill="currentColor" stroke="none"/>
                  <line x1="4" y1="18" x2="20" y2="18"/>
                  <circle cx="10" cy="18" r="2" fill="currentColor" stroke="none"/>
                </svg>
                <span class="text-xs font-medium">Filter by activity</span>
                <span
                  id="filter-badge"
                  class="hidden text-[10px] font-bold leading-none bg-[var(--color-brand-600)] text-white rounded-full px-1.5 py-0.5"
                ></span>
              </button>
            </div>
          </nav>

          <!-- Only articles scroll -->
          <div id="articles-scroll" class="flex-1 min-h-0 overflow-y-auto">

            <!-- Empty state -->
            <div id="empty-state" class="hidden text-center py-20">
              <svg class="w-8 h-8 mx-auto mb-3 text-[var(--color-text-muted)] opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <p class="text-[var(--color-text-muted)] text-sm">No guides found for this filter.</p>
              <button id="empty-clear-btn" class="mt-3 text-xs text-[var(--color-brand-600)] hover:underline">Clear filters</button>
            </div>

            <!-- Articles feed -->
            <div id="articles-list" class="pt-6">
              {allArticles.map((article) => (
                <ArticleCard
                  title={article.data.title}
                  description={article.data.description}
                  destination={article.data.destination}
                  category={article.data.category}
                  slug={article.id}
                  heroImage={article.data.heroImage}
                  readingTime={article.data.readingTime}
                  city={article.data.city}
                  tags={article.data.tags}
                />
              ))}
            </div>

            <!-- Newsletter -->
            <div class="mt-16 mb-4">
              <NewsletterSignup />
            </div>

          </div>

        </div>
      </div>

      <!-- Right sidebar -->
      <aside
        class="hidden lg:flex flex-col shrink-0"
        style="width: 439px; padding: 2.5rem 1.5rem 2.5rem 30px; overflow-y: auto;"
      >
        <TrendingNow />
      </aside>

    </div>
  </div>

  <!-- Vertical divider -->
  <div class="hidden lg:block fixed pointer-events-none" style="right: 439px; top: calc(4rem + 3.25rem); bottom: 0; width: 1px; background: var(--color-border);"></div>

  <!-- ── Filter Modal ── -->
  <div
    id="filter-modal-overlay"
    class="hidden fixed inset-0 z-[200] flex items-start justify-center"
    style="background: rgba(0,0,0,0.25); padding-top: calc(4rem + 3.25rem + 2.5rem + 2.5rem);"
  >
    <div
      id="filter-modal"
      class="bg-white rounded-2xl shadow-2xl w-full flex flex-col"
      style="max-width: 560px; max-height: 70vh;"
      role="dialog"
      aria-modal="true"
      aria-labelledby="filter-modal-title"
    >
      <!-- Modal header -->
      <div class="flex items-center justify-between px-6 pt-5 pb-4 border-b border-[var(--color-border)] shrink-0">
        <h2 id="filter-modal-title" class="text-sm font-semibold text-[var(--color-text-primary)]" style="font-family: var(--font-body);">Filters</h2>
        <button id="filter-modal-close" class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors" aria-label="Close filters" type="button">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Modal body -->
      <div class="overflow-y-auto flex-1 px-6 py-5 space-y-6">

        <!-- Category section -->
        <div>
          <p class="text-[10px] font-semibold uppercase tracking-widest text-[var(--color-text-muted)] mb-3">Category</p>
          <div class="flex flex-wrap gap-2">
            {categories.map((cat) => (
              <button class="modal-pill category-pill-btn" data-category={cat.id}>
                {cat.label}
              </button>
            ))}
          </div>
        </div>

        <!-- Activity type section -->
        <div>
          <p class="text-[10px] font-semibold uppercase tracking-widest text-[var(--color-text-muted)] mb-3">Activity type</p>
          <div class="flex flex-wrap gap-2">
            {activityTypes.map((type) => (
              <button class="modal-pill activity-pill-btn" data-type={type.id}>
                {type.label}
              </button>
            ))}
          </div>
        </div>

      </div>

      <!-- Modal footer -->
      <div class="flex items-center justify-between px-6 py-4 border-t border-[var(--color-border)] shrink-0">
        <button
          id="filter-clear-btn"
          class="text-sm font-medium text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors"
          type="button"
        >
          Clear all
        </button>
        <button
          id="filter-apply-btn"
          class="px-5 py-2 rounded-full text-sm font-semibold bg-[var(--color-brand-600)] text-white hover:opacity-90 transition-opacity"
          type="button"
        >
          Apply
        </button>
      </div>
    </div>
  </div>

</BaseLayout>

<style>
  /* ── Tabs ──────────────────────────────────────────────────── */
  .hub-tab {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    cursor: pointer;
    background: none;
    border-top: none; border-left: none; border-right: none;
    transition: color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }
  .hub-tab:hover { color: var(--color-text-primary); }
  .hub-tab.is-active {
    color: var(--color-text-primary);
    border-bottom-color: var(--color-text-primary);
    font-weight: 600;
  }

  /* ── Filter icon button active state ──────────────────────── */
  .filter-icon-btn.has-filters {
    color: var(--color-brand-600);
    border-bottom-color: var(--color-brand-600);
  }

  /* ── Modal pills ───────────────────────────────────────────── */
  .modal-pill {
    padding: 0.3rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.8rem;
    font-weight: 400;
    border: none;
    background: #f2f2f2;
    color: var(--color-text-primary);
    cursor: pointer;
    transition: background 0.12s, color 0.12s;
    line-height: 1.6;
    white-space: nowrap;
  }
  .modal-pill:hover { background: #e8e8e8; }
  .modal-pill.is-active {
    background: var(--color-brand-600);
    color: #fff;
    font-weight: 500;
  }

  /* ── Articles scroll — no visible scrollbar ────────────────── */
  #articles-scroll { scrollbar-width: none; }
  #articles-scroll::-webkit-scrollbar { display: none; }

  /* ── Modal overlay animation ───────────────────────────────── */
  #filter-modal-overlay { transition: opacity 0.15s; }
  #filter-modal-overlay.hidden { opacity: 0; pointer-events: none; }
</style>

<script>
  // ── State ────────────────────────────────────────────────────
  const cards   = document.querySelectorAll<HTMLElement>('[data-article-card]');
  const emptyEl = document.getElementById('empty-state');
  const listEl  = document.getElementById('articles-list');
  const countEl = document.getElementById('article-count');

  // Applied filters (what the feed is actually filtered by)
  const activeCategories = new Set<string>();
  let activeType: string | null = null;

  // Pending filters (inside modal, not yet applied)
  const pendingCategories = new Set<string>();
  let pendingType: string | null = null;

  // ── Type keywords ────────────────────────────────────────────
  const typeKeywords: Record<string, string[]> = {
    'food-drink':   ['food', 'cuisine', 'restaurant', 'eating', 'market', 'ramen', 'sushi', 'bbq', 'street food'],
    'temples':      ['temple', 'shrine', 'buddhist', 'shinto'],
    'nature':       ['nature', 'rural', 'mountain', 'forest', 'island', 'jeju'],
    'shopping':     ['shopping', 'market', 'harajuku', 'myeongdong', 'ginza'],
    'history':      ['history', 'historical', 'palace', 'joseon', 'edo', 'samurai'],
    'museums':      ['museum', 'art', 'exhibit', 'culture'],
    'onsen':        ['onsen', 'hot spring', 'bath', 'jjimjilbang'],
    'festivals':    ['festival', 'sakura', 'matsuri', 'seasonal'],
    'castles':      ['castle', 'palace', 'gyeongbokgung'],
    'architecture': ['architecture', 'hanok', 'machiya', 'traditional'],
  };

  function typeMatch(tags: string, typeId: string | null): boolean {
    if (!typeId) return true;
    return (typeKeywords[typeId] ?? []).some((kw) => tags.includes(kw));
  }

  // ── Apply filters to feed ────────────────────────────────────
  function applyFilters() {
    let visible = 0;
    cards.forEach((card) => {
      const category = (card.dataset.category ?? '').toLowerCase();
      const tags     = card.dataset.tags ?? '';
      const show = (activeCategories.size === 0 || activeCategories.has(category))
                && typeMatch(tags, activeType);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (emptyEl) emptyEl.style.display = visible === 0 ? '' : 'none';
    if (listEl)  listEl.style.display  = visible === 0 ? 'none' : '';
    if (countEl) countEl.textContent   = String(visible);
    updateFilterBadge();
  }

  // ── Badge on filter icon ─────────────────────────────────────
  function updateFilterBadge() {
    const badge = document.getElementById('filter-badge');
    const btn   = document.getElementById('filter-btn');
    const total = activeCategories.size + (activeType ? 1 : 0);
    if (badge) {
      badge.textContent = total > 0 ? String(total) : '';
      badge.classList.toggle('hidden', total === 0);
    }
    btn?.classList.toggle('has-filters', total > 0);
  }

  // ── Modal open / close ───────────────────────────────────────
  const overlay  = document.getElementById('filter-modal-overlay');
  const modal    = document.getElementById('filter-modal');

  function openModal() {
    // Sync pending state from applied state
    pendingCategories.clear();
    activeCategories.forEach((c) => pendingCategories.add(c));
    pendingType = activeType;
    syncModalPills();
    overlay?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    overlay?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  document.getElementById('filter-btn')?.addEventListener('click', openModal);
  document.getElementById('filter-modal-close')?.addEventListener('click', closeModal);

  // Click outside modal to close
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeModal();
  });

  // Escape to close
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !overlay?.classList.contains('hidden')) closeModal();
  });

  // ── Sync pill UI inside modal ────────────────────────────────
  function syncModalPills() {
    document.querySelectorAll<HTMLButtonElement>('.category-pill-btn[data-category]').forEach((btn) => {
      btn.classList.toggle('is-active', pendingCategories.has(btn.dataset.category!));
    });
    document.querySelectorAll<HTMLButtonElement>('.activity-pill-btn[data-type]').forEach((btn) => {
      btn.classList.toggle('is-active', btn.dataset.type === pendingType);
    });
  }

  // ── Category pills (pending, inside modal) ───────────────────
  document.querySelectorAll<HTMLButtonElement>('.category-pill-btn[data-category]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.category!;
      if (pendingCategories.has(cat)) {
        pendingCategories.delete(cat);
        btn.classList.remove('is-active');
      } else {
        pendingCategories.add(cat);
        btn.classList.add('is-active');
      }
    });
  });

  // ── Activity type pills (pending, single select) ─────────────
  document.querySelectorAll<HTMLButtonElement>('.activity-pill-btn[data-type]').forEach((btn) => {
    btn.addEventListener('click', () => {
      pendingType = btn.dataset.type === pendingType ? null : btn.dataset.type!;
      syncModalPills();
    });
  });

  // ── Apply button ─────────────────────────────────────────────
  document.getElementById('filter-apply-btn')?.addEventListener('click', () => {
    activeCategories.clear();
    pendingCategories.forEach((c) => activeCategories.add(c));
    activeType = pendingType;
    applyFilters();
    closeModal();
  });

  // ── Clear all (inside modal) ─────────────────────────────────
  document.getElementById('filter-clear-btn')?.addEventListener('click', () => {
    pendingCategories.clear();
    pendingType = null;
    syncModalPills();
  });

  // ── Clear filters from empty state ───────────────────────────
  document.getElementById('empty-clear-btn')?.addEventListener('click', () => {
    activeCategories.clear();
    activeType = null;
    applyFilters();
  });

  // ── typeFilter event (from TrendingNow / city filter) ────────
  document.addEventListener('goinatlas:typeFilter', ((e: CustomEvent) => {
    activeType = e.detail.type;
    applyFilters();
  }) as EventListener);

  // ── Redirect wheel events to articles scroll ─────────────────
  // The page itself doesn't scroll; capture wheel anywhere on the
  // shell and forward the delta to the only scrollable container.
  const shell       = document.getElementById('home-shell');
  const scrollEl    = document.getElementById('articles-scroll');

  shell?.addEventListener('wheel', (e) => {
    if (!scrollEl) return;
    // If the event originated inside articles-scroll, let it scroll natively
    if (scrollEl.contains(e.target as Node)) return;
    e.preventDefault();
    scrollEl.scrollTop += e.deltaY;
  }, { passive: false });
</script>
