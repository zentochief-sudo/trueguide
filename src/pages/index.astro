---
import BaseLayout from '../layouts/BaseLayout.astro';
import DestinationCard from '../components/DestinationCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import SearchBar from '../components/SearchBar.astro';
import { getCollection } from 'astro:content';

const japanArticles = await getCollection('japan');
const allArticles = [
  ...japanArticles,
].sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const destinations = [
  {
    name: 'Japan',
    slug: 'japan',
    tagline: 'Between chaos and silence — the country that rewires you.',
    heroImage: '/images/japan-hero.jpg',
    articleCount: japanArticles.length,
  },
  {
    name: 'South Korea',
    slug: 'korea',
    tagline: 'Ancient temples, K-culture and food that changes your standards.',
    heroImage: '/images/korea-hero.jpg',
    articleCount: 0,
  },
];

const tabs = [
  { id: 'all', label: 'All Guides' },
  { id: 'japan', label: 'Japan' },
  { id: 'korea', label: 'South Korea' },
];
---

<BaseLayout
  title="Deep Travel Guides for the Curious Traveler"
  description="TrueGuide — deep, honest travel guides for Japan, South Korea and beyond. Itineraries, food guides, and travel planning templates."
>
  <!-- Hero -->
  <section class="relative bg-[var(--color-text-primary)] text-white overflow-hidden">
    <div class="absolute inset-0 opacity-20 bg-cover bg-center" style="background-image: url('/images/hero-bg.jpg')" />
    <div class="relative max-w-4xl mx-auto px-6 py-24 md:py-36 text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--color-brand-400)] mb-6">
        Deep travel guides
      </p>
      <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-6" style="font-family: var(--font-editorial)">
        Travel like someone<br />who actually knows.
      </h1>
      <p class="text-lg text-white/70 max-w-xl mx-auto leading-relaxed mb-10">
        No recycled listicles. No sponsored fluff. Just the kind of guide your most well-traveled friend would write.
      </p>

      <!-- Search bar -->
      <SearchBar variant="hero" />

      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a href="/japan" class="bg-[var(--color-brand-600)] hover:bg-[var(--color-brand-700)] text-white font-semibold px-8 py-3.5 rounded-xl transition-colors">
          Explore Japan
        </a>
        <a href="/korea" class="bg-white/10 hover:bg-white/20 border border-white/20 text-white font-semibold px-8 py-3.5 rounded-xl transition-colors">
          South Korea →
        </a>
      </div>
    </div>
  </section>

  <!-- Tabs + article grid — immediately below hero -->
  <section class="max-w-6xl mx-auto px-6 pt-12 pb-8">
    <!-- Tab bar -->
    <div class="border-b border-[var(--color-border)] mb-8">
      <div class="flex gap-0 -mb-px" id="home-tabs">
        {tabs.map((tab, i) => (
          <button
            class={[
              'tab-btn whitespace-nowrap px-5 py-3 text-sm border-b-2 transition-colors',
              i === 0
                ? 'font-semibold border-[var(--color-brand-600)] text-[var(--color-brand-600)]'
                : 'font-medium border-transparent text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)]',
            ].join(' ')}
            data-tab={tab.id}
          >
            {tab.label}
          </button>
        ))}
      </div>
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden text-center py-16">
      <p class="text-[var(--color-text-muted)] text-sm">No guides found. Try a different search.</p>
    </div>

    <!-- Korea coming soon (shown when Korea tab active and no articles) -->
    <div id="korea-empty" class="hidden text-center py-20">
      <p class="text-2xl mb-3" style="font-family: var(--font-editorial)">South Korea</p>
      <p class="text-[var(--color-text-muted)] text-sm max-w-xs mx-auto">First guides dropping soon. Subscribe to the newsletter to get notified.</p>
    </div>

    <!-- Articles grid -->
    <div id="articles-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {allArticles.map((article) => (
        <ArticleCard
          title={article.data.title}
          description={article.data.description}
          destination={article.data.destination}
          category={article.data.category}
          slug={article.id}
          heroImage={article.data.heroImage}
          readingTime={article.data.readingTime}
        />
      ))}
    </div>
  </section>

  <!-- Destinations -->
  <section class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex items-end justify-between mb-8">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-text-muted)] mb-1">Where to go</p>
        <h2 class="text-3xl font-bold text-[var(--color-text-primary)]" style="font-family: var(--font-editorial)">Destinations</h2>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {destinations.map((dest) => (
        <DestinationCard {...dest} />
      ))}
    </div>
  </section>

  <!-- Newsletter -->
  <section class="max-w-4xl mx-auto px-6 pb-20">
    <NewsletterSignup />
  </section>
</BaseLayout>

<script>
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const cards = document.querySelectorAll<HTMLElement>('[data-article-card]');
  const emptyState = document.getElementById('empty-state');
  const koreaEmpty = document.getElementById('korea-empty');
  const grid = document.getElementById('articles-grid');

  let activeTab = 'all';
  let searchQuery = '';

  function applyFilters() {
    let visible = 0;
    let isKoreaTabEmpty = false;

    // Show/hide korea empty state
    if (activeTab === 'korea' && !searchQuery) {
      const koreaCards = Array.from(cards).filter((c) => c.dataset.destination === 'korea');
      isKoreaTabEmpty = koreaCards.length === 0;
    }

    cards.forEach((card) => {
      const matchesTab = activeTab === 'all' || card.dataset.destination === activeTab;
      const matchesSearch =
        !searchQuery ||
        card.dataset.title?.includes(searchQuery) ||
        card.dataset.description?.includes(searchQuery);

      const show = matchesTab && matchesSearch;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    if (grid) grid.classList.toggle('hidden', isKoreaTabEmpty);
    if (koreaEmpty) koreaEmpty.classList.toggle('hidden', !(isKoreaTabEmpty && !searchQuery));
    if (emptyState) {
      const showEmpty = visible === 0 && !isKoreaTabEmpty;
      emptyState.classList.toggle('hidden', !showEmpty);
    }
  }

  function setActiveTab(tab: string) {
    activeTab = tab;
    tabBtns.forEach((btn) => {
      const isActive = btn.dataset.tab === tab;
      btn.classList.toggle('border-[var(--color-brand-600)]', isActive);
      btn.classList.toggle('text-[var(--color-brand-600)]', isActive);
      btn.classList.toggle('font-semibold', isActive);
      btn.classList.toggle('border-transparent', !isActive);
      btn.classList.toggle('text-[var(--color-text-muted)]', !isActive);
      btn.classList.toggle('font-medium', !isActive);
    });
    applyFilters();
  }

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => setActiveTab(btn.dataset.tab!));
  });

  // Respond to search from the hero SearchBar
  document.addEventListener('trueguide:search', ((e: CustomEvent) => {
    searchQuery = e.detail.query;
    // When searching, reset tab visually to "All" so all destinations are searched
    if (searchQuery) {
      activeTab = 'all';
      tabBtns.forEach((btn) => {
        const isAll = btn.dataset.tab === 'all';
        btn.classList.toggle('border-[var(--color-brand-600)]', isAll);
        btn.classList.toggle('text-[var(--color-brand-600)]', isAll);
        btn.classList.toggle('font-semibold', isAll);
        btn.classList.toggle('border-transparent', !isAll);
        btn.classList.toggle('text-[var(--color-text-muted)]', !isAll);
        btn.classList.toggle('font-medium', !isAll);
      });
    }
    applyFilters();
  }) as EventListener);
</script>
