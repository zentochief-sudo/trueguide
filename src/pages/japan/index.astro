---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import JapanMap from '../../components/JapanMap.astro';
import FilterSidebar from '../../components/FilterSidebar.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('japan');
const sorted = articles.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

// Build city list with counts
const cityMap: Record<string, number> = {};
for (const a of sorted) {
  const c = a.data.city ?? 'national';
  cityMap[c] = (cityMap[c] ?? 0) + 1;
}

const cityOrder = ['tokyo', 'kyoto', 'osaka', 'kanazawa', 'hiroshima', 'nara', 'national'];
const cityLabels: Record<string, string> = {
  tokyo: 'Tokyo', kyoto: 'Kyoto', osaka: 'Osaka',
  kanazawa: 'Kanazawa', hiroshima: 'Hiroshima', nara: 'Nara',
  national: 'All Japan',
};

const cities = cityOrder
  .filter((id) => cityMap[id])
  .map((id) => ({ id, label: cityLabels[id] ?? id, count: cityMap[id] }));
---

<BaseLayout
  title="Japan Travel Guides"
  description="Deep Japan travel guides — itineraries, food, hidden spots and honest tips for first-timers and repeat visitors."
>
  <!-- Destination hero: map + headline -->
  <div class="bg-white border-b border-[var(--color-border)] py-10 px-6">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-10">
      <!-- Text -->
      <div class="flex-1 text-center md:text-left">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-text-muted)] mb-2">
          {sorted.length} guides
        </p>
        <h1
          class="text-[40px] leading-tight font-black text-[var(--color-text-primary)] mb-3"
          style="font-family: var(--font-display); font-weight: 900;"
        >
          Japan
        </h1>
        <p class="text-[var(--color-text-secondary)] max-w-sm">
          Between chaos and silence — the country that rewires how you see the world.
        </p>
      </div>
      <!-- Map -->
      <div class="flex-1 w-full">
        <JapanMap />
      </div>
    </div>
  </div>

  <!-- Sidebar + articles -->
  <div class="max-w-6xl mx-auto px-6 py-10">
    <div class="flex flex-col md:flex-row gap-10">
      <!-- Sidebar -->
      <FilterSidebar cities={cities} destination="Japan" />

      <!-- Articles -->
      <div class="flex-1 min-w-0">
        <!-- Empty state -->
        <div id="empty-state" class="hidden text-center py-16">
          <p class="text-[var(--color-text-muted)] text-sm">No guides found for this city yet.</p>
        </div>

        <div id="articles-grid" class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {sorted.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              destination={article.data.destination}
              category={article.data.category}
              slug={article.id}
              heroImage={article.data.heroImage}
              readingTime={article.data.readingTime}
              city={article.data.city}
            />
          ))}
        </div>

        <div class="mt-20">
          <NewsletterSignup destination="Japan" />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const cards = document.querySelectorAll<HTMLElement>('[data-article-card]');
  const emptyState = document.getElementById('empty-state');
  const grid = document.getElementById('articles-grid');

  function filterByCity(cityId: string) {
    let visible = 0;
    cards.forEach((card) => {
      const cardCity = card.dataset.city ?? 'national';
      const show = cityId === 'all' || cardCity === cityId;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (emptyState) emptyState.style.display = visible === 0 ? '' : 'none';
    if (grid) grid.style.display = visible === 0 ? 'none' : '';
  }

  document.addEventListener('goinatlas:cityFilter', ((e: CustomEvent) => {
    filterByCity(e.detail.city);
  }) as EventListener);
</script>
