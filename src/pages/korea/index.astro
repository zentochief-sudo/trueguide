---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import KoreaMap from '../../components/KoreaMap.astro';
import FilterSidebar from '../../components/FilterSidebar.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('korea');
const sorted = articles.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const cityMap: Record<string, number> = {};
for (const a of sorted) {
  const c = a.data.city ?? 'national';
  cityMap[c] = (cityMap[c] ?? 0) + 1;
}

// 'national' excluded — FilterSidebar already renders "All Korea" as the first option
const cityOrder = ['seoul', 'busan', 'gyeongju', 'jeju'];
const cityLabels: Record<string, string> = {
  seoul: 'Seoul', busan: 'Busan', gyeongju: 'Gyeongju',
  jeju: 'Jeju Island', national: 'All Korea',
};

const cities = cityOrder
  .filter((id) => cityMap[id])
  .map((id) => ({ id, label: cityLabels[id] ?? id, count: cityMap[id] }));
---

<BaseLayout
  title="South Korea Travel Guides"
  description="Deep South Korea travel guides — Seoul, Busan, Gyeongju and beyond. Itineraries, food, K-culture and honest travel tips."
>
  <!-- Hero: headline + map -->
  <div class="bg-white border-b border-[var(--color-border)] py-10 px-6">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-10">
      <div class="flex-1 text-center md:text-left">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-text-muted)] mb-2">
          {sorted.length} guides
        </p>
        <h1
          class="text-[40px] leading-tight font-black text-[var(--color-text-primary)] mb-3"
          style="font-family: var(--font-display); font-weight: 900;"
        >
          South Korea
        </h1>
        <p class="text-[var(--color-text-secondary)] max-w-sm mb-5">
          Ancient temples, neon-lit alleys, and food that makes you reconsider every meal you've had before.
        </p>

        <!-- Search scope checkbox -->
        <label class="inline-flex items-center gap-2 cursor-pointer select-none group" id="scope-label">
          <span class="relative flex items-center">
            <input
              type="checkbox"
              id="search-scope-checkbox"
              checked
              class="peer sr-only"
            />
            <span class="w-4 h-4 rounded border-2 border-[var(--color-brand-600)] bg-white peer-checked:bg-[var(--color-brand-600)] transition-colors flex items-center justify-center flex-shrink-0">
              <svg class="w-2.5 h-2.5 text-white hidden peer-checked:block" fill="none" viewBox="0 0 10 10">
                <path d="M1.5 5l2.5 2.5 4.5-4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </span>
          <span class="text-xs text-[var(--color-text-secondary)] group-hover:text-[var(--color-text-primary)] transition-colors">
            Searching within <strong class="font-semibold">South Korea</strong>
          </span>
        </label>
      </div>
      <div class="w-full md:w-64">
        <KoreaMap />
      </div>
    </div>
  </div>

  <!-- Breadcrumb — sticky once it reaches the top -->
  <div class="sticky z-[29] border-b border-[var(--color-border)] bg-[var(--color-bg)] shadow-sm" style="top: var(--header-h, 10.5rem)">
    <nav aria-label="Breadcrumb" class="py-3 px-6 max-w-6xl mx-auto">
      <ol id="hub-breadcrumb" class="flex items-center flex-wrap gap-1 text-sm" itemscope itemtype="https://schema.org/BreadcrumbList">
        <li class="flex items-center gap-1" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="/" itemprop="item" class="text-[var(--color-text-muted)] hover:text-[var(--color-brand-600)] transition-colors font-medium"><span itemprop="name">Home</span></a>
          <meta itemprop="position" content="1" />
        </li>
        <li class="flex items-center gap-1" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <svg class="w-3.5 h-3.5 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <span itemprop="name" class="text-[var(--color-text-primary)] font-semibold">South Korea</span>
          <meta itemprop="position" content="2" />
        </li>
        <li id="breadcrumb-city-crumb" class="hidden flex items-center gap-1" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <svg class="w-3.5 h-3.5 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <span id="breadcrumb-city-label" itemprop="name" class="text-[var(--color-text-primary)] font-semibold"></span>
          <meta itemprop="position" content="3" />
        </li>
      </ol>
    </nav>
  </div>

  <!-- Sidebar + articles -->
  <div class="max-w-6xl mx-auto px-6 py-10">
    <div class="flex flex-col md:flex-row gap-10">
      <FilterSidebar cities={cities} destination="South Korea" />

      <div class="flex-1 min-w-0">
        <div id="empty-state" class="hidden text-center py-16">
          <p class="text-[var(--color-text-muted)] text-sm">No guides found for this filter.</p>
        </div>

        <div id="articles-grid" class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {sorted.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              destination={article.data.destination}
              category={article.data.category}
              slug={article.id}
              heroImage={article.data.heroImage}
              readingTime={article.data.readingTime}
              city={article.data.city}
              tags={article.data.tags}
            />
          ))}
        </div>

        <div class="mt-20">
          <NewsletterSignup destination="South Korea" />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const cards    = document.querySelectorAll<HTMLElement>('[data-article-card]');
  const emptyEl  = document.getElementById('empty-state');
  const gridEl   = document.getElementById('articles-grid');
  const checkbox = document.getElementById('search-scope-checkbox') as HTMLInputElement;

  const typeKeywords: Record<string, string[]> = {
    'food-drink':   ['food', 'cuisine', 'restaurant', 'eating', 'market', 'korean food', 'bbq', 'street food'],
    'shrines':      ['shrine', 'haedong', 'temple'],
    'onsen':        ['onsen', 'jjimjilbang', 'bath', 'sauna'],
    'parks':        ['park', 'garden', 'namsan', 'hangang'],
    'temples':      ['temple', 'buddhist', 'beomeosa', 'jogyesa'],
    'castles':      ['castle', 'palace', 'gyeongbokgung', 'joseon'],
    'architecture': ['architecture', 'hanok', 'bukchon', 'traditional'],
    'crafts':       ['craft', 'artisan', 'pottery', 'insadong'],
    'festivals':    ['festival', 'seasonal', 'cherry blossom'],
    'nature':       ['nature', 'rural', 'island', 'jeju', 'taejongdae'],
    'manga-anime':  ['k-drama', 'kdrama', 'filming', 'kpop', 'hallyu'],
    'museums':      ['museum', 'theatre', 'art', 'exhibit', 'culture'],
    'shopping':     ['shopping', 'market', 'myeongdong', 'hongdae', 'jagalchi'],
    'history':      ['history', 'historical', 'palace', 'joseon', 'war'],
    'luxury':       ['luxury', 'high-end', 'michelin', 'omakase'],
  };

  let activeCity: string = 'all';
  let activeCategory: string | null = null;
  let activeType: string | null = null;

  function applyFilters() {
    let visible = 0;
    cards.forEach((card) => {
      const city     = card.dataset.city ?? 'national';
      const category = card.dataset.category ?? '';
      const tags     = card.dataset.tags ?? '';

      const matchCity     = activeCity === 'all' || city === activeCity;
      const matchCategory = !activeCategory || category === activeCategory.toLowerCase();
      let   matchType     = true;
      if (activeType) {
        const kws = typeKeywords[activeType] ?? [];
        matchType = kws.some((kw) => tags.includes(kw));
      }

      const show = matchCity && matchCategory && matchType;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (emptyEl) emptyEl.style.display = visible === 0 ? '' : 'none';
    if (gridEl)  gridEl.style.display  = visible === 0 ? 'none' : '';
  }

  // ── Breadcrumb city update ────────────────────────────────────
  const cityLabelsBC: Record<string, string> = {
    seoul: 'Seoul', busan: 'Busan', gyeongju: 'Gyeongju', jeju: 'Jeju Island',
  };
  const cityCrumb  = document.getElementById('breadcrumb-city-crumb');
  const cityLabel  = document.getElementById('breadcrumb-city-label');

  function updateBreadcrumb(cityId: string) {
    if (!cityCrumb || !cityLabel) return;
    if (cityId === 'all') {
      cityCrumb.classList.add('hidden');
    } else {
      cityLabel.textContent = cityLabelsBC[cityId] ?? cityId;
      cityCrumb.classList.remove('hidden');
    }
  }

  document.addEventListener('goinatlas:cityFilter', ((e: CustomEvent) => {
    activeCity = e.detail.city;
    updateBreadcrumb(e.detail.city);
    applyFilters();
  }) as EventListener);

  document.addEventListener('goinatlas:categoryFilter', ((e: CustomEvent) => {
    activeCategory = e.detail.category;
    applyFilters();
  }) as EventListener);

  document.addEventListener('goinatlas:typeFilter', ((e: CustomEvent) => {
    activeType = e.detail.type;
    applyFilters();
  }) as EventListener);

  function updateScope() {
    document.dispatchEvent(new CustomEvent('goinatlas:searchScope', {
      detail: { destination: checkbox?.checked ? 'South Korea' : null },
    }));
  }

  checkbox?.addEventListener('change', updateScope);
  document.addEventListener('DOMContentLoaded', updateScope);
</script>
